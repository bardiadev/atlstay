---
// Sticky mobile call-to-action bar. Most local "airbnb management near me"
// searches happen on phones, so every mobile page gets a persistent, one-tap
// way to CALL or request a projection. Hidden on lg+ (desktop has the header
// phone + CTA). Body reserves bottom padding so this never hides the footer.
import { site } from '../../config/site';
---
<div class="fixed inset-x-0 bottom-0 z-40 xl:hidden">
  <div class="flex gap-2 border-t border-line/70 bg-cream/95 px-3 pt-2.5 pb-[calc(0.625rem+env(safe-area-inset-bottom))] backdrop-blur-md">
    <a
      href={site.contact.phoneHref}
      class="flex flex-1 items-center justify-center gap-2 rounded-full bg-brass px-4 py-3 text-sm font-semibold text-forest-900 shadow-sm transition-transform active:scale-[0.98]"
      aria-label={`Call ${site.brandName} at ${site.contact.phone}`}
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24c1.14.38 2.35.58 3.6.58a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.58 3.6a1 1 0 0 1-.24 1z" />
      </svg>
      Call now
    </a>
    <a
      href="/rental-projection/"
      class="flex flex-1 items-center justify-center rounded-full bg-forest px-4 py-3 text-sm font-semibold text-cream shadow-sm transition-transform active:scale-[0.98]"
    >
      Free projection
    </a>
  </div>
</div>
