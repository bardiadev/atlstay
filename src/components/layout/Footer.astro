---
import { footerNav } from '../../data/navigation';
import { site } from '../../config/site';
import Logo from './Logo.astro';
const year = new Date().getFullYear();
const a = site.contact.address;
const loc = [a.city, a.region].filter(Boolean).join(', ');
const mailing = a.street ? `${a.street}, ${a.city}, ${a.region} ${a.postalCode}`.trim() : '';
---
<footer class="bg-forest text-cream/80">
  <div class="mx-auto max-w-7xl px-6 py-16 sm:px-8">
    <div class="grid gap-12 lg:grid-cols-[1.5fr_repeat(4,1fr)]">
      <div>
        <Logo variant="light" />
        <p class="mt-4 max-w-xs text-sm text-cream/65">{site.description}</p>
        <div class="mt-6 space-y-1.5 text-sm">
          <a href={site.contact.phoneHref} class="block hover:text-brass">{site.contact.phone}</a>
          <a href={`mailto:${site.contact.email}`} class="block hover:text-brass">{site.contact.email}</a>
          {loc && <p class="text-cream/55">Serving {loc} &amp; metro Atlanta</p>}
          {mailing && (
            <address class="not-italic text-cream/45">{mailing}</address>
          )}
          <p class="pt-1.5 text-cream/55">
            Powered by <a href={site.company.url} rel="noopener" class="font-medium text-cream/80 underline-offset-2 hover:text-brass">{site.company.legalName}</a>
          </p>
        </div>
      </div>

      {footerNav.map((col) => (
        <div>
          <h4 class="font-display text-sm text-cream">{col.heading}</h4>
          <ul class="mt-4 space-y-2.5">
            {col.links.map((l) => (
              <li><a href={l.href} class="text-sm text-cream/65 transition-colors hover:text-brass">{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-14 flex flex-col items-start justify-between gap-4 border-t border-cream/15 pt-8 text-xs text-cream/55 sm:flex-row sm:items-center">
      <p>© {year} {site.brandName} — a brand of <a href={site.company.url} rel="noopener" class="underline-offset-2 hover:text-brass">{site.company.legalName}</a>. All rights reserved.</p>
      <div class="flex flex-wrap gap-x-6 gap-y-2">
        <a href={site.company.mapsUrl} target="_blank" rel="noopener" class="hover:text-brass">Reviews on Google</a>
        <a href="/privacy/" class="hover:text-brass">Privacy</a>
        <a href="/terms/" class="hover:text-brass">Terms</a>
        <a href="/contact/" class="hover:text-brass">Contact</a>
      </div>
    </div>
  </div>
</footer>
