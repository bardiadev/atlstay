---
// Small "related guides" block — links money pages back to resource articles
// to complete the internal link graph. Self-contained (brings its own Section).
import Container from './Container.astro';
import Section from './Section.astro';
import Eyebrow from './Eyebrow.astro';

interface Item {
  title: string;
  desc: string;
  href: string;
}
interface Props {
  items: Item[];
  heading?: string;
  variant?: 'white' | 'cream' | 'tint';
}
const { items, heading = 'Keep reading', variant = 'white' } = Astro.props;
---

<Section variant={variant}>
  <Container>
    <Eyebrow>Related guides</Eyebrow>
    <h2 class="mt-3 font-display text-2xl text-forest sm:text-3xl">{heading}</h2>
    <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((it) => (
        <a
          href={it.href}
          class="group flex flex-col rounded-2xl border border-line bg-white p-6 shadow-sm transition-all hover:-translate-y-0.5 hover:border-brass/60 hover:shadow-md"
        >
          <h3 class="font-display text-lg leading-snug text-forest transition-colors group-hover:text-brass-600">
            {it.title}
          </h3>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-ink/75">{it.desc}</p>
          <span class="mt-4 text-sm font-medium text-brass-600">Read the guide &rarr;</span>
        </a>
      ))}
    </div>
  </Container>
</Section>
