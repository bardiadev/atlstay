---
import type { CardStyle } from '../../lib/cardImage';

interface Props {
  name: string;
  href: string;
  blurb?: string;
  gradient?: string; // CSS background-image value from assignCardStyles
  icon?: CardStyle['icon'];
}

const {
  name,
  href,
  blurb,
  gradient = 'linear-gradient(135deg,#1c4a3c,#0e241d)',
  icon = 'building',
} = Astro.props;
---
<a
  href={href}
  style={`background-image:${gradient}`}
  class="group relative flex aspect-[4/3] flex-col justify-end overflow-hidden rounded-2xl border border-cream/10 p-5 shadow-sm ring-1 ring-inset ring-white/[0.05] transition duration-300 hover:-translate-y-1 hover:shadow-xl hover:ring-brass/40"
>
  <!-- Quiet category icon: adds texture and distinguishes market type without photos -->
  <svg
    class="pointer-events-none absolute -bottom-5 -right-4 h-32 w-32 text-cream/[0.07] transition-transform duration-500 group-hover:scale-105"
    viewBox="0 0 24 24"
    fill="currentColor"
    aria-hidden="true"
  >
    {icon === 'mountain' && <path d="M1 21 8.5 6l3.5 7 2.5-4L23 21z" />}
    {icon === 'house' && <path d="M12 2 2 11h3v11h6v-7h2v7h6V11h3z" />}
    {icon === 'wave' && (
      <g fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M1 8c3-3.5 6-3.5 9 0s6 3.5 9 0" />
        <path d="M1 14c3-3.5 6-3.5 9 0s6 3.5 9 0" />
        <path d="M1 20c3-3.5 6-3.5 9 0s6 3.5 9 0" />
      </g>
    )}
    {icon === 'building' && <path d="M3 22V8l5-2v16zM9 22V4l6-2v20zM16 22V10l5 3v9z" />}
  </svg>

  <!-- Premium brass hairline along the top edge -->
  <span class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brass/40 to-transparent"></span>

  <div class="relative z-10">
    <h3 class="font-display text-xl text-cream sm:text-2xl">{name}</h3>
    {blurb && <p class="mt-1.5 line-clamp-2 text-sm text-cream/75">{blurb}</p>}
    <span class="mt-3 inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wide text-brass">
      Explore
      <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </span>
  </div>
</a>
