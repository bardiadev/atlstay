---
interface Props {
  class?: string;
  size?: 'narrow' | 'default' | 'wide';
}
const { class: cls = '', size = 'default' } = Astro.props;
const widths = { narrow: 'max-w-3xl', default: 'max-w-6xl', wide: 'max-w-7xl' };
---
<div class={`mx-auto w-full px-6 sm:px-8 ${widths[size]} ${cls}`}><slot /></div>
