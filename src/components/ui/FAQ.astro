---
import { faqPageSchema } from '../../lib/schema';
// Renders an accordion AND (by default) emits FAQPage JSON-LD. Use emitSchema
// only ONCE per page to avoid duplicate FAQPage markup.
interface Props { items: { q: string; a: string }[]; emitSchema?: boolean; class?: string; }
const { items, emitSchema = true, class: cls = '' } = Astro.props;
const schema = emitSchema ? faqPageSchema(items) : null;
---
<div class={`divide-y divide-line ${cls}`}>
  {items.map((f) => (
    <details class="group py-5">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left [&::-webkit-details-marker]:hidden">
        <span class="font-display text-lg text-forest">{f.q}</span>
        <svg class="h-5 w-5 flex-none text-brass-600 transition-transform duration-200 group-open:rotate-45" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M10 4v12M4 10h12" stroke-linecap="round" />
        </svg>
      </summary>
      <p data-speakable class="mt-3 leading-relaxed text-ink/80">{f.a}</p>
    </details>
  ))}
</div>
{schema && <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />}
