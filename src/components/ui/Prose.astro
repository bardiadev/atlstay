---
// Long-form content wrapper (used by resource articles / markdown <Content/>).
// Plain CSS using theme tokens — no Tailwind-typography dependency.
interface Props { class?: string; }
const { class: cls = '' } = Astro.props;
---
<div class={`prose-keystone ${cls}`}><slot /></div>

<style is:global>
  .prose-keystone {
    color: color-mix(in srgb, var(--color-ink) 88%, transparent);
    line-height: 1.75;
    font-size: 1.0625rem;
  }
  .prose-keystone > * + * { margin-top: 1.25rem; }
  .prose-keystone h2 {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2rem);
    color: var(--color-forest);
    letter-spacing: -0.015em;
    margin-top: 2.75rem;
  }
  .prose-keystone h3 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--color-forest);
    margin-top: 2rem;
  }
  .prose-keystone a {
    color: var(--color-brass-600);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-keystone a:hover { color: var(--color-brass); }
  .prose-keystone ul { list-style: disc; padding-left: 1.5rem; }
  .prose-keystone ol { list-style: decimal; padding-left: 1.5rem; }
  .prose-keystone li + li { margin-top: 0.5rem; }
  .prose-keystone strong { font-weight: 600; color: var(--color-forest); }
  .prose-keystone blockquote {
    border-left: 4px solid var(--color-brass);
    padding-left: 1.25rem;
    font-style: italic;
    color: color-mix(in srgb, var(--color-ink) 75%, transparent);
  }
  .prose-keystone table { width: 100%; border-collapse: collapse; font-size: 0.95rem; }
  .prose-keystone th, .prose-keystone td { border: 1px solid var(--color-line); padding: 0.5rem 0.75rem; text-align: left; }
  .prose-keystone th { background: var(--color-forest-50); font-weight: 600; }
  .prose-keystone hr { border: 0; border-top: 1px solid var(--color-line); margin: 2.5rem 0; }
</style>
