---
// Global interior-page hero. By DEFAULT it embeds the live rental-projection
// form right in the hero (copy left, form right on desktop; stacked on mobile)
// so every landing page, location page, and article puts the most important
// thing — the form — immediately in front of the visitor, no click required.
// Pass `hideForm` for pages with their own form (e.g. /contact/).
import Container from './Container.astro';
import Button from './Button.astro';
import { images, type ImageKey } from '../../data/images';
import { site } from '../../config/site';
import ProjectionForm from '../react/ProjectionForm';

interface Crumb { name: string; path: string; }
interface Props {
  title: string;
  subtitle?: string;
  eyebrow?: string;
  imageKey?: ImageKey;
  image?: string;
  imageAlt?: string;
  breadcrumbs?: Crumb[];
  align?: 'left' | 'center';
  size?: 'sm' | 'md' | 'lg';
  cta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  /** Hide the embedded lead form (pages that have their own form, e.g. /contact/). */
  hideForm?: boolean;
}
const {
  title, subtitle, eyebrow, imageKey, image, imageAlt,
  breadcrumbs = [], align = 'left', size = 'md', cta, secondaryCta, hideForm = false,
} = Astro.props;

const img = image
  ? { src: image, alt: imageAlt ?? '' }
  : imageKey
    ? images[imageKey]
    : images.atlantaSkyline;

const centered = hideForm && align === 'center';
const minH = hideForm ? { sm: 'min-h-[32vh]', md: 'min-h-[44vh]', lg: 'min-h-[56vh]' }[size] : '';
---
<section class={`relative isolate flex items-center overflow-hidden py-12 sm:py-16 ${minH}`}>
  <img
    src={img.src}
    alt={img.alt}
    width="1920"
    height="1080"
    loading="eager"
    fetchpriority="high"
    class="absolute inset-0 -z-20 h-full w-full object-cover object-center"
  />
  <div class="absolute inset-0 -z-10 bg-gradient-to-r from-forest/95 via-forest/85 to-forest/60"></div>
  <div class="absolute inset-0 -z-10 bg-gradient-to-t from-forest/70 via-transparent to-forest/30"></div>

  <Container>
    <div class={hideForm ? '' : 'grid items-center gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:gap-14'}>
      <!-- Left: copy -->
      <div class={`${hideForm ? `max-w-3xl ${centered ? 'mx-auto text-center' : ''}` : 'max-w-xl text-center lg:text-left'}`}>
        {breadcrumbs.length > 0 && (
          <nav aria-label="Breadcrumb" class="mb-4">
            <ol class={`flex flex-wrap items-center gap-1.5 text-xs text-cream/70 ${centered ? 'justify-center' : 'justify-center lg:justify-start'}`}>
              {breadcrumbs.map((c, i) => (
                <li class="flex items-center gap-1.5">
                  {i > 0 && <span class="text-cream/40">/</span>}
                  {i < breadcrumbs.length - 1
                    ? <a href={c.path} class="transition-colors hover:text-brass">{c.name}</a>
                    : <span class="text-cream">{c.name}</span>}
                </li>
              ))}
            </ol>
          </nav>
        )}
        {eyebrow && <p class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-brass">{eyebrow}</p>}
        <h1 class="font-display text-[clamp(1.85rem,4vw,3rem)] font-medium leading-[1.08] tracking-tight text-balance text-cream">
          {title}
        </h1>
        {subtitle && (
          <p class={`mt-4 max-w-lg text-base leading-relaxed text-cream/85 sm:text-lg ${hideForm && centered ? 'mx-auto' : 'mx-auto lg:mx-0'}`}>
            {subtitle}
          </p>
        )}

        {hideForm ? (
          (cta || secondaryCta) && (
            <div class={`mt-7 flex flex-col gap-3 sm:flex-row sm:items-center ${centered ? 'sm:justify-center' : ''}`}>
              {cta && <Button href={cta.href} size="lg">{cta.label}</Button>}
              {secondaryCta && <Button href={secondaryCta.href} variant="inverse" size="lg">{secondaryCta.label}</Button>}
            </div>
          )
        ) : (
          <div class="mt-6 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-sm lg:justify-start">
            <span class="text-cream/85">{site.scale.ratingPhrase}</span>
            <span class="hidden text-cream/40 sm:inline">·</span>
            <a href={site.contact.phoneHref} class="font-medium text-cream transition-colors hover:text-brass">Call {site.contact.phone}</a>
            {secondaryCta && (
              <Fragment>
                <span class="hidden text-cream/40 sm:inline">·</span>
                <a href={secondaryCta.href} class="text-cream/80 underline-offset-4 transition-colors hover:text-brass hover:underline">{secondaryCta.label}</a>
              </Fragment>
            )}
          </div>
        )}
      </div>

      <!-- Right: live projection form -->
      {!hideForm && (
        <div class="w-full">
          <p class="mb-3 flex items-center justify-center gap-2 text-sm font-medium text-cream lg:justify-start">
            <span class="inline-block h-2 w-2 rounded-full bg-brass"></span>
            Free rental projection — about a minute
          </p>
          <ProjectionForm client:load />
          <p class="mt-3 text-center text-xs text-cream/70">
            Free, no obligation. Prefer to talk? Call
            <a href={site.contact.phoneHref} class="underline underline-offset-2 hover:text-brass">{site.contact.phone}</a>.
          </p>
        </div>
      )}
    </div>
  </Container>
</section>
