---
interface Props { variant?: 'brass' | 'forest' | 'outline'; class?: string; }
const { variant = 'brass', class: cls = '' } = Astro.props;
const v = {
  brass: 'bg-brass-50 text-brass-600 ring-1 ring-brass/30',
  forest: 'bg-forest-50 text-forest ring-1 ring-forest/15',
  outline: 'ring-1 ring-line text-stone',
};
---
<span class={`inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium ${v[variant]} ${cls}`}>
  <slot />
</span>
