---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import Eyebrow from '@/components/ui/Eyebrow.astro';
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';
import Card from '@/components/ui/Card.astro';
import StepList from '@/components/ui/StepList.astro';
import CheckList from '@/components/ui/CheckList.astro';
import FAQ from '@/components/ui/FAQ.astro';
import LogoCloud from '@/components/ui/LogoCloud.astro';
import CTABand from '@/components/ui/CTABand.astro';
import TestimonialCard from '@/components/ui/TestimonialCard.astro';
import NeighborhoodCard from '@/components/ui/NeighborhoodCard.astro';
import ProjectionForm from '@/components/react/ProjectionForm';
import { serviceSchema } from '@/lib/schema';
import { site } from '@/config/site';
import { services } from '@/data/services';
import { testimonials } from '@/data/testimonials';
import { homeFaqs } from '@/data/faqs';
import { images } from '@/data/images';

const homeSchemas = [
  serviceSchema({
    name: 'Short-term rental management',
    description:
      'Full-service Airbnb and Vrbo management for Atlanta and Georgia homeowners — listing, dynamic pricing, 24/7 guest care, cleaning, and transparent reporting.',
  }),
];

// Show first 6 services on homepage
const featuredServices = services.slice(0, 6);

const howItWorksSteps = [
  {
    title: 'Get your free projection',
    text: 'Tell us about your home. We pull real Atlanta comps and send you a custom, honest earnings estimate — built by a person, not an algorithm — within one business day.',
  },
  {
    title: 'We set everything up',
    text: 'Professional photography, listing creation, dynamic pricing, and a complete readiness check. Your home launches polished and ready to earn.',
  },
  {
    title: 'We run the whole operation',
    text: 'Guests, cleaning, maintenance, reviews — we handle every detail. You stay in control of your calendar and house rules. We do the rest.',
  },
  {
    title: 'You receive your payout',
    text: 'Reliable monthly payouts with a clear statement showing exactly how your home performed. Total transparency, every time.',
  },
];

const neighborhoods = [
  {
    name: 'Buckhead',
    href: '/atlanta/buckhead/',
    imageKey: 'nbhdBuckhead' as const,
    blurb: 'Atlanta\'s premier address. Corporate travelers, luxury stays, and strong year-round demand.',
  },
  {
    name: 'Midtown',
    href: '/atlanta/midtown/',
    imageKey: 'nbhdMidtown' as const,
    blurb: 'Arts, culture, Piedmont Park, and walkable demand from Georgia Tech and major employers.',
  },
  {
    name: 'Old Fourth Ward',
    href: '/atlanta/old-fourth-ward/',
    imageKey: 'nbhdOldFourthWard' as const,
    blurb: 'The BeltLine\'s most vibrant stretch. Design-forward properties with exceptional guest draw.',
  },
  {
    name: 'Inman Park',
    href: '/atlanta/inman-park/',
    imageKey: 'nbhdInmanPark' as const,
    blurb: 'Historic charm, walkable to Little Five Points and the BeltLine. A guest favorite.',
  },
  {
    name: 'Virginia-Highland',
    href: '/atlanta/virginia-highland/',
    imageKey: 'nbhdDefault' as const,
    blurb: 'Boutique neighborhood with loyal guest following and strong weekend and event demand.',
  },
  {
    name: 'Grant Park',
    href: '/atlanta/grant-park/',
    imageKey: 'nbhdDefault' as const,
    blurb: 'Steps from Zoo Atlanta and major event venues. Excellent family and group bookings.',
  },
  {
    name: 'East Atlanta Village',
    href: '/atlanta/east-atlanta-village/',
    imageKey: 'nbhdDefault' as const,
    blurb: 'Creative energy, independent restaurants, and a growing short-term rental market.',
  },
  {
    name: 'Decatur',
    href: '/atlanta/decatur/',
    imageKey: 'nbhdDecatur' as const,
    blurb: 'Award-winning schools, a beloved downtown square, and a thriving arts scene.',
  },
];

const differentiators = [
  `Management fee from ${site.pricing.rate} — ${site.pricing.rateNote}`,
  'Full-service: listing, guests, cleaning, maintenance, reviews',
  '24/7 local response — not a national call center',
  site.features.noLockIn ? 'No long-term contracts — stay because results speak' : 'Clear, simple agreements with no surprises',
  site.features.guarantee ? `${site.features.guaranteeText} — we stand behind our work` : 'We only take on homes we\'re confident we can perform for',
  'Atlanta-specific pricing: conventions, concerts, sports demand',
  'Professional photography included — no nickle-and-diming',
  'Transparent monthly reporting — always know your numbers',
];
---

<BaseLayout
  title="Atlanta Short-Term Rental Management"
  description="Premium short-term rental management in Atlanta. Professional listing, dynamic pricing, 24/7 guest care, and five-star turnovers — handled for you. Get a free rental projection."
  schemas={homeSchemas}
>

  <!-- ─── HERO ─── (copy + live projection form; viewport-fit on desktop) -->
  <section class="relative isolate flex items-center overflow-hidden py-12 lg:min-h-[calc(100svh-5rem)] lg:py-0">
    <img
      src={images.heroHome.src}
      alt={images.heroHome.alt}
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 -z-20 h-full w-full object-cover object-center"
    />
    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-forest/95 via-forest/85 to-forest/60"></div>
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-forest/70 via-transparent to-forest/30"></div>

    <Container>
      <div class="grid items-center gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:gap-14">
        <!-- Left: copy -->
        <div class="max-w-xl">
          <Badge variant="brass" class="mb-4">Atlanta's local short-term rental experts</Badge>
          <h1 class="font-display text-[clamp(2rem,4.4vw,3.25rem)] font-medium leading-[1.07] tracking-tight text-balance text-cream">
            Effortless Airbnb management in Atlanta.
          </h1>
          <p class="mt-4 max-w-lg text-base leading-relaxed text-cream/85 sm:text-lg">
            Premium short-term rental management for local homeowners — listing, pricing, 24/7 guest care, cleaning, and five-star reviews handled for you, so your home earns more without the work.
          </p>

          <dl class="mt-8 hidden flex-wrap gap-x-8 gap-y-3 border-t border-cream/20 pt-6 lg:flex">
            <div><dt class="font-display text-xl text-cream">{site.stats.reviews}</dt><dd class="mt-0.5 text-xs text-cream/70">five-star reviews</dd></div>
            <div><dt class="font-display text-xl text-cream">{site.stats.homes}</dt><dd class="mt-0.5 text-xs text-cream/70">homes managed</dd></div>
            <div><dt class="font-display text-xl text-cream">{site.stats.years} yrs</dt><dd class="mt-0.5 text-xs text-cream/70">managing Atlanta STRs</dd></div>
          </dl>

          <div class="mt-6 hidden items-center gap-4 text-sm lg:flex">
            <a href="/how-it-works/" class="font-medium text-cream underline-offset-4 hover:text-brass hover:underline">See how it works &rarr;</a>
            <span class="text-cream/40">·</span>
            <a href={site.contact.phoneHref} class="text-cream/80 transition-colors hover:text-brass">Call {site.contact.phone}</a>
          </div>
        </div>

        <!-- Right: live projection form -->
        <div class="w-full">
          <p class="mb-3 flex items-center gap-2 text-sm font-medium text-cream">
            <span class="inline-block h-2 w-2 rounded-full bg-brass"></span>
            Free rental projection — about a minute
          </p>
          <ProjectionForm client:load />
          <p class="mt-3 text-center text-xs text-cream/70">
            No obligation — ever. Prefer to talk? Call
            <a href={site.contact.phoneHref} class="underline underline-offset-2 hover:text-brass">{site.contact.phone}</a>.
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- ─── LOGO CLOUD / PLATFORM STRIP ─── -->
  <Section variant="cream" class="!py-0">
    <div class="border-y border-line">
      <LogoCloud heading="Your home, listed everywhere guests book" />
    </div>
  </Section>

  <!-- ─── PROBLEM → SOLUTION ─── -->
  <Section variant="white">
    <Container>
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16 lg:items-center">

        <!-- Problem side -->
        <div>
          <Eyebrow>The self-managing trap</Eyebrow>
          <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">
            Managing your own Airbnb is a second job. An exhausting one.
          </h2>
          <div class="mt-6 space-y-4 text-ink/75">
            <p>Message volume you didn't expect. Cleaning crews that cancel the night before. A guest leaves a 4-star review because the wifi password was wrong. Dynamic pricing that takes a full course to understand.</p>
            <p>Most self-managing owners spend <strong class="text-ink">15–25 hours a week</strong> on their rental — and still leave revenue on the table because they're pricing off instinct, not data.</p>
          </div>
          <div class="mt-8 rounded-2xl border border-line bg-cream p-6">
            <p class="font-display text-xl text-forest">The local advantage you've been missing.</p>
            <p class="mt-2 text-ink/75">Atlanta's calendar is packed with demand drivers — conventions at the GWCC, SEC Championship weekends, Braves and Falcons games, Peach Bowl, and a global arts scene. Knowing when to push rates and when to stay competitive takes constant local attention. That's what we do, every single day.</p>
          </div>
        </div>

        <!-- Solution side -->
        <div>
          <Eyebrow>The ATLStay difference</Eyebrow>
          <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">
            Premium local management. Handled entirely for you.
          </h2>
          <p class="mt-4 text-ink/75">We're not a national platform that learned Atlanta from a spreadsheet. We manage homes in these neighborhoods, know the demand patterns, and treat every property like it's the only one we have.</p>
          <div class="mt-6">
            <CheckList
              columns={1}
              items={[
                'Professional listing creation and ongoing optimization',
                'Nightly dynamic pricing using real local demand data',
                '24/7 guest communication — every message answered fast',
                'Hotel-grade cleaners and thorough turnover quality checks',
                'Maintenance coordination with trusted local vendors',
                'Transparent owner reporting and reliable monthly payouts',
              ]}
            />
          </div>
          <div class="mt-8">
            <Button href="/rental-projection/" size="lg">See what your home could earn</Button>
          </div>
        </div>

      </div>
    </Container>
  </Section>

  <!-- ─── SERVICES OVERVIEW ─── -->
  <Section variant="cream">
    <Container>
      <div class="text-center">
        <Eyebrow>Full-service management</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">
          Everything your rental needs. Nothing you have to do.
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-ink/75">
          From the first professional photo to every five-star review — we handle the complete operation so you stay a property owner, not an accidental hotelier.
        </p>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featuredServices.map((service) => (
          <Card class="flex flex-col">
            <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-forest-50">
              <svg class="h-5 w-5 text-forest" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M10 2l2.4 4.8 5.4.8-3.9 3.8.9 5.4L10 14.3l-4.8 2.5.9-5.4-3.9-3.8 5.4-.8L10 2z" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h3 class="font-display text-lg text-forest">{service.title}</h3>
            <p class="mt-1.5 text-sm font-medium text-brass-600">{service.short}</p>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-ink/75">{service.description}</p>
          </Card>
        ))}
      </div>
      <div class="mt-10 text-center">
        <Button href="/services/" variant="secondary">See everything we handle</Button>
      </div>
    </Container>
  </Section>

  <!-- ─── DYNAMIC PRICING SPOTLIGHT ─── -->
  <Section variant="tint">
    <Container>
      <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <Eyebrow>The #1 profit lever</Eyebrow>
          <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">Most hosts leave money on the table — every single night.</h2>
          <p class="mt-5 text-lg leading-relaxed text-ink/80">
            The biggest driver of what a short-term rental earns isn't the furniture or the photos — it's the <strong class="text-forest">pricing</strong>. And almost everyone sets it once and forgets it.
          </p>
          <p class="mt-4 leading-relaxed text-ink/75">
            We don't. We reprice your calendar <strong class="text-forest">every single day</strong> — every night priced individually around real demand, Atlanta's event calendar, and what comparable homes are doing. We raise rates ahead of the convention you didn't know was coming, and protect occupancy before a slow week leaves you empty.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
            <Button href="/dynamic-pricing/" size="lg">How our pricing works</Button>
            <Button href="/rental-projection/" variant="ghost" size="lg">Get my free projection &rarr;</Button>
          </div>
        </div>
        <div class="rounded-3xl border border-line bg-white p-8 shadow-sm">
          <p class="font-display text-lg text-forest">What "managed daily" actually means</p>
          <ul class="mt-5 space-y-4 text-sm">
            {[
              ['Every night priced individually', 'Never a lazy flat weekday/weekend rate.'],
              ['Updated every single day', 'Your calendar is reviewed and adjusted daily — not once at setup.'],
              ['Event-aware', 'Conventions, games, concerts, festivals — priced ahead of the surge.'],
              ['Software plus a local human', 'Data tools, plus a revenue manager who actually knows Atlanta.'],
            ].map(([t, dd]) => (
              <li class="flex items-start gap-3">
                <svg class="mt-0.5 h-5 w-5 flex-none text-brass-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.3 3.3 6.8-6.8a1 1 0 0 1 1.4 0z" clip-rule="evenodd" /></svg>
                <span class="text-ink/85"><span class="font-semibold text-forest">{t}</span> — {dd}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </Container>
  </Section>

  <!-- ─── PROBLEMS WE SOLVE ─── -->
  <Section variant="white">
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <Eyebrow>Problems we solve</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">Hosting is full of ways to lose money. We close every one.</h2>
        <p class="mt-4 text-ink/75">The gap between a property that thrives and one that drains you is rarely one big thing — it's a dozen small ones, handled or not.</p>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {[
          { problem: 'Set-and-forget pricing', solution: 'We reprice every day around demand and events — the single biggest lever in what you earn.' },
          { problem: 'Empty nights & weak occupancy', solution: 'Listed everywhere guests book, with daily pricing that keeps the calendar full at the right rate.' },
          { problem: '2 a.m. guest messages', solution: '24/7 local guest communication — every message handled fast, so your reviews stay five-star.' },
          { problem: 'Unreliable cleaners & messy turnovers', solution: 'Vetted local cleaning teams, a strict turnover checklist, and a quality check before every guest.' },
          { problem: 'Maintenance emergencies', solution: 'A trusted local vendor network — we act first on urgent issues so a broken AC never becomes a bad review.' },
          { problem: "It's become a second job", solution: 'We run the entire operation end to end. You stay an owner — never an operator.' },
        ].map((p) => (
          <div class="rounded-2xl border border-line bg-cream p-6">
            <p class="text-xs font-semibold uppercase tracking-wider text-stone">The problem</p>
            <h3 class="mt-1 font-display text-lg text-forest">{p.problem}</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink/80"><span class="font-semibold text-brass-600">Our fix —</span> {p.solution}</p>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- ─── WHY KEYSTONE DIFFERENTIATORS ─── -->
  <Section variant="forest">
    <Container>
      <div class="text-center">
        <Eyebrow class="text-brass">Why ATLStay</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-cream sm:text-4xl">
          The local authority. The national quality.
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-cream/70">
          National brands know scale. Local operators know the neighborhood. We're the only STR manager in Atlanta built to deliver both — in one team, with one clear fee.
        </p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">

        <div class="rounded-2xl bg-white/5 p-6 ring-1 ring-white/10">
          <div class="mb-4 font-display text-3xl text-brass">From {site.pricing.rate}</div>
          <h3 class="font-display text-lg text-cream">One all-in fee</h3>
          <p class="mt-2 text-sm leading-relaxed text-cream/65">
            {site.pricing.rateNote}. No setup costs, no surprise line items. Your exact rate depends on your property and market — and you see it before you sign.
          </p>
        </div>

        <div class="rounded-2xl bg-white/5 p-6 ring-1 ring-white/10">
          <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-brass/15 text-brass">
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 16V4M3 16h14" /><path d="M6 12l3-3 2 2 4-5" /></svg>
          </div>
          <h3 class="font-display text-lg text-cream">Daily dynamic pricing</h3>
          <p class="mt-2 text-sm leading-relaxed text-cream/65">
            We reprice your calendar every day around Atlanta's events and demand — the biggest driver of what your home earns.
            <a href="/dynamic-pricing/" class="text-brass underline-offset-2 hover:underline">See how &rarr;</a>
          </p>
        </div>

        {site.features.guarantee && (
          <div class="rounded-2xl bg-white/5 p-6 ring-1 ring-white/10">
            <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-brass/15 text-brass">
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2l6 2v5c0 4-2.7 7-6 9-3.3-2-6-5-6-9V4l6-2z" /><path d="M7.5 10l1.7 1.7L13 8" /></svg>
            </div>
            <h3 class="font-display text-lg text-cream">{site.features.guaranteeText}</h3>
            <!-- CONFIRM guarantee terms with owner before publishing -->
            <p class="mt-2 text-sm leading-relaxed text-cream/65">
              We stand behind the results. If we fall short of expectations in the first six months, we make it right — no bureaucracy, no runaround.
            </p>
          </div>
        )}

        {site.features.noLockIn && (
          <div class="rounded-2xl bg-white/5 p-6 ring-1 ring-white/10">
            <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-brass/15 text-brass">
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="9" width="12" height="8" rx="1.5" /><path d="M7 9V6.5a3 3 0 0 1 5.8-1.1" /></svg>
            </div>
            <h3 class="font-display text-lg text-cream">No lock-in, ever</h3>
            <!-- CONFIRM no-lock-in terms with owner -->
            <p class="mt-2 text-sm leading-relaxed text-cream/65">
              No long-term contracts. We earn your partnership every month with results. Stay because it's working — leave anytime if it's not.
            </p>
          </div>
        )}

        {!site.features.guarantee && (
          <div class="rounded-2xl bg-white/5 p-6 ring-1 ring-white/10">
            <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-brass/15 text-brass">
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="10" cy="10" r="7" /><circle cx="10" cy="10" r="3" /></svg>
            </div>
            <h3 class="font-display text-lg text-cream">Performance-first model</h3>
            <p class="mt-2 text-sm leading-relaxed text-cream/65">
              We only earn when your home earns. Our incentives are perfectly aligned with yours — we succeed when you do.
            </p>
          </div>
        )}

        {!site.features.noLockIn && (
          <div class="rounded-2xl bg-white/5 p-6 ring-1 ring-white/10">
            <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-brass/15 text-brass">
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h12v8H8l-4 3V5z" /></svg>
            </div>
            <h3 class="font-display text-lg text-cream">Real people, real answers</h3>
            <p class="mt-2 text-sm leading-relaxed text-cream/65">
              24/7 local guest support from a team that knows your property — not a national call center following a script.
            </p>
          </div>
        )}

      </div>

      <div class="mt-12 rounded-2xl bg-white/5 p-8 ring-1 ring-white/10">
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          <!-- Scale phrases are credible-but-vague by design — never fabricated precise stats -->
          <div class="text-cream">
            <p class="font-display text-lg text-brass leading-snug">{site.scale.portfolioPhrase}</p>
            <p class="mt-1 text-xs text-cream/60">homes under management</p>
          </div>
          <div class="text-cream">
            <p class="font-display text-lg text-brass leading-snug">{site.scale.staysPhrase}</p>
            <p class="mt-1 text-xs text-cream/60">delivered for Atlanta owners</p>
          </div>
          <div class="text-cream">
            <p class="font-display text-lg text-brass leading-snug">{site.scale.bookingsPhrase}</p>
            <p class="mt-1 text-xs text-cream/60">in bookings managed</p>
          </div>
          <div class="text-cream">
            <p class="font-display text-lg text-brass leading-snug">{site.scale.ratingPhrase}</p>
            <p class="mt-1 text-xs text-cream/60">across every property</p>
          </div>
        </div>
      </div>

    </Container>
  </Section>

  <!-- ─── HOW IT WORKS (condensed) ─── -->
  <Section variant="white">
    <Container>
      <div class="grid gap-12 lg:grid-cols-[1fr_1.2fr] lg:gap-20 lg:items-start">
        <div>
          <Eyebrow>Simple by design</Eyebrow>
          <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">
            From first conversation to first payout in four steps.
          </h2>
          <p class="mt-4 text-ink/75">
            We've built a process that gets your home earning fast — with full transparency at every stage. Most properties are live and taking bookings within two weeks of signing.
          </p>
          <Button href="/how-it-works/" variant="secondary" class="mt-8">See the full process</Button>
        </div>
        <div>
          <StepList steps={howItWorksSteps} />
        </div>
      </div>
    </Container>
  </Section>

  <!-- ─── ATLANTA NEIGHBORHOODS GRID ─── -->
  <Section variant="cream">
    <Container>
      <div class="text-center">
        <Eyebrow>We know Atlanta</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">
          Neighborhood expertise that no national brand can fake.
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-ink/75">
          From Buckhead to Decatur, each Atlanta neighborhood has its own demand profile, seasonality, and guest expectations. We manage in all of them.
        </p>
      </div>
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
