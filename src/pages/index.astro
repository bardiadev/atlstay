---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
---

<BaseLayout title="foundation check">
  <main class="grid min-h-screen place-items-center px-6">
    <div class="text-center">
      <p class="font-display text-5xl text-forest sm:text-6xl">Keystone Stays</p>
      <p class="mt-4 text-stone">Foundation ready. Alias + tokens + components working.</p>
      <Button href="/services/" class="mt-6">Alias check</Button>
    </div>
  </main>
</BaseLayout>
