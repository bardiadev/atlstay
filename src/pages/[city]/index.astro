---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/ui/PageHero.astro';
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import Eyebrow from '@/components/ui/Eyebrow.astro';
import Button from '@/components/ui/Button.astro';
import NeighborhoodCard from '@/components/ui/NeighborhoodCard.astro';
import FAQ from '@/components/ui/FAQ.astro';
import CTABand from '@/components/ui/CTABand.astro';
import Prose from '@/components/ui/Prose.astro';
import CheckList from '@/components/ui/CheckList.astro';
import { breadcrumbSchema, serviceSchema } from '@/lib/schema';
import { images, type ImageKey } from '@/data/images';
import { site } from '@/config/site';
import { cityGeo } from '@/data/cityGeo';
import { assignCardImages } from '@/lib/cardImage';

export async function getStaticPaths() {
  const c = await getCollection('cities');
  return c.filter((e) => e.data.published).map((e) => ({ params: { city: e.data.slug }, props: { entry: e } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const isAtlanta = d.region === 'atlanta';

// Local geo (frontmatter first, then the cityGeo map) — powers schema + copy
const mapGeo = cityGeo[d.slug];
const lat = typeof d.lat === 'number' ? d.lat : mapGeo?.lat;
const lng = typeof d.lng === 'number' ? d.lng : mapGeo?.lng;
const county = d.county ?? mapGeo?.county;
const countyOf = (c: typeof entry) => c.data.county ?? cityGeo[c.data.slug]?.county;

const isVacation = d.region === 'georgia';
const heading = `${isVacation ? 'Vacation Rental & Airbnb Management' : 'Airbnb & Short-Term Rental Management'} in ${d.name}, ${d.state}`;
const seoTitle = isVacation ? `Vacation Rental Management in ${d.name}, GA` : `Airbnb Management in ${d.name}, GA`;
const countyLine = county ? ` We manage homes across ${d.name} and ${county} County.` : '';

// Neighborhoods (Atlanta only)
const allNeighborhoods = await getCollection('neighborhoods', (n) => n.data.published && n.data.citySlug === d.slug);
const neighborhoodMap = Object.fromEntries(allNeighborhoods.map((n) => [n.data.slug, n]));
const orderedNeighborhoods = d.neighborhoods.map((slug) => neighborhoodMap[slug]).filter(Boolean);
// Varied, non-repeating card imagery for the neighborhood grid.
const nbhdImgs = assignCardImages(orderedNeighborhoods.map((n) => ({ slug: n.data.slug, region: 'atlanta' })));

// Nearby markets — same county first, then same region (internal linking)
const allCities = await getCollection('cities', (c) => c.data.published);
const regionLabel = d.region === 'georgia' ? 'Across Georgia' : 'Metro Atlanta';
const byName = (a: typeof entry, b: typeof entry) => a.data.name.localeCompare(b.data.name);
const sameCounty = (county ? allCities.filter((c) => c.data.slug !== d.slug && countyOf(c) === county) : []).sort(byName);
const sameRegion = allCities
  .filter((c) => c.data.slug !== d.slug && (isAtlanta ? c.data.region === 'metro' : c.data.region === d.region))
  .sort(byName);
const nearby = [...new Map([...sameCounty, ...sameRegion].map((c) => [c.data.slug, c])).values()].slice(0, 8);

const heroKey: ImageKey = d.heroImage && d.heroImage in images ? (d.heroImage as ImageKey) : 'atlantaSkyline';

const schemas = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Areas We Serve', path: '/areas-we-serve/' },
    { name: d.name, path: `/${d.slug}/` },
  ]),
  serviceSchema({
    name: heading,
    description: d.description,
    area: { name: `${d.name}, ${d.state}`, lat, lng, county },
  }),
];
---

<BaseLayout title={seoTitle} description={d.description} image={images[heroKey].src} schemas={schemas}>
  <PageHero
    title={heading}
    subtitle={d.intro}
    eyebrow={`${d.name} · Airbnb & Vrbo management`}
    imageKey={heroKey}
    breadcrumbs={[
      { name: 'Home', path: '/' },
      { name: 'Areas We Serve', path: '/areas-we-serve/' },
      { name: d.name, path: `/${d.slug}/` },
    ]}
    cta={{ label: 'Get my free rental projection', href: '/rental-projection/' }}
    secondaryCta={{ label: 'All areas we serve', href: '/areas-we-serve/' }}
    size="lg"
  />

  <!-- What we deliver -->
  <Section variant="cream">
    <Container>
      <div class="grid gap-12 lg:grid-cols-2 lg:items-start lg:gap-20">
        <div>
          <Eyebrow>What we deliver</Eyebrow>
          <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">Full-service management in {d.name}</h2>
          <p class="mt-4 text-ink/80">
            ATLStay handles every part of your {d.name} short-term rental — listing creation and professional photography, dynamic pricing, 24/7 guest communication, cleaning, and turnovers. One transparent rate, {site.pricing.rateNote}.{countyLine}
          </p>
          <Button href="/services/" variant="secondary" class="mt-6">See all services &rarr;</Button>
        </div>
        {d.highlights.length > 0 && (
          <div class="rounded-2xl border border-line bg-white p-8">
            <h3 class="font-display text-lg text-forest">Why ATLStay in {d.name}</h3>
            <div class="mt-4"><CheckList items={d.highlights} /></div>
          </div>
        )}
      </div>
    </Container>
  </Section>

  <!-- Neighborhoods grid (Atlanta) -->
  {orderedNeighborhoods.length > 0 && (
    <Section variant="white">
      <Container size="wide">
        <div class="mb-10 text-center">
          <Eyebrow>{d.name} neighborhoods</Eyebrow>
          <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">Neighborhoods we serve in {d.name}</h2>
          <p class="mx-auto mt-4 max-w-2xl text-ink/70">Each {d.name} neighborhood has its own demand profile and guest mix. We manage properties across all of them.</p>
        </div>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {orderedNeighborhoods.map((n, i) => (
            <NeighborhoodCard name={n.data.name} href={`/${d.slug}/${n.data.slug}/`} imageSrc={nbhdImgs[i].src} imageAlt={nbhdImgs[i].alt} blurb={n.data.intro.split('.')[0] + '.'} />
          ))}
        </div>
      </Container>
    </Section>
  )}

  <!-- Why local management matters -->
  <Section variant="forest">
    <Container>
      <div class="mx-auto max-w-3xl text-center">
        <Eyebrow class="text-brass">Local vs. national</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-cream sm:text-4xl">The {d.name} advantage: local knowledge at every level</h2>
        <p class="mt-5 text-cream/80">
          National STR platforms run algorithms, not relationships — pricing from national datasets, remote contractor turnovers, and call-center support with no feel for your market. ATLStay is different: we know {d.name}'s demand patterns, event calendar, and the local vendor relationships that make turnovers reliable and reviews five-star.
        </p>
        <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-3">
          {[
            { value: '24/7', label: 'Local guest support' },
            { value: site.pricing.rate, label: 'All-inclusive management rate' },
            { value: '5★', label: site.scale.ratingPhrase },
          ].map((stat) => (
            <div class="rounded-xl border border-cream/15 bg-cream/5 p-6">
              <div class="font-display text-2xl text-brass">{stat.value}</div>
              <div class="mt-1 text-sm text-cream/70">{stat.label}</div>
            </div>
          ))}
        </div>
        <Button href="/rental-projection/" size="lg" class="mt-10">Get my free {d.name} projection</Button>
      </div>
    </Container>
  </Section>

  <!-- Rich body -->
  <Section variant="white">
    <Container size="narrow"><Prose><Content /></Prose></Container>
  </Section>

  <!-- Regulations: Atlanta-specific vs general (never assert wrong local rules) -->
  <Section variant="cream">
    <Container>
      <div class="rounded-2xl border border-line bg-white px-8 py-10">
        {isAtlanta ? (
          <div class="grid gap-8 lg:grid-cols-2 lg:items-center">
            <div>
              <Eyebrow>Regulatory compliance</Eyebrow>
              <h2 class="mt-3 font-display text-2xl text-forest sm:text-3xl">{d.name} short-term rental regulations</h2>
              <p class="mt-4 text-ink/80">The City of Atlanta requires a Short-Term Rental License, and DeKalb County introduced its own program effective May 2026. Operating without the right permits can mean steep fines. We guide every client through compliance and stay current as rules change.</p>
            </div>
            <div class="space-y-4">
              <div class="rounded-lg border border-line p-4">
                <div class="text-sm font-medium text-forest">City of Atlanta STRL</div>
                <div class="mt-1 text-sm text-ink/70">~$150/year · primary-residence rules · via atl311.com</div>
              </div>
              <div class="rounded-lg border border-line p-4">
                <div class="text-sm font-medium text-forest">DeKalb County (eff. May 2026)</div>
                <div class="mt-1 text-sm text-ink/70">~$175/year · local-contact requirement</div>
              </div>
              <Button href="/resources/atlanta-short-term-rental-regulations/" variant="secondary" class="w-full text-center">Full Atlanta STR regulations guide &rarr;</Button>
            </div>
          </div>
        ) : (
          <div class="grid gap-8 lg:grid-cols-[2fr_1fr] lg:items-center">
            <div>
              <Eyebrow>Regulatory compliance</Eyebrow>
              <h2 class="mt-3 font-display text-2xl text-forest sm:text-3xl">{d.name} short-term rental rules — handled</h2>
              <p class="mt-4 text-ink/80">Short-term rental permitting in Georgia varies by city and county — licensing, occupancy taxes, and local rules differ from one market to the next. ATLStay helps every {d.name} owner navigate the local requirements and stay compliant, and we keep current as rules change.</p>
              <p class="mt-3 text-ink/80">Always confirm the latest rules with {d.name}'s local authority before you list — we'll point you to exactly what applies to your property.</p>
            </div>
            <Button href="/resources/atlanta-short-term-rental-regulations/" variant="secondary" class="self-start text-center">Georgia STR regulations guide &rarr;</Button>
          </div>
        )}
      </div>
    </Container>
  </Section>

  <!-- Nearby markets (internal linking) -->
  {nearby.length > 0 && (
    <Section variant="white">
      <Container>
        <div class="mb-8 text-center">
          <Eyebrow>{regionLabel}</Eyebrow>
          <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">Nearby areas we manage</h2>
        </div>
        <div class="flex flex-wrap justify-center gap-3">
          {nearby.map((c) => (
            <a href={`/${c.data.slug}/`} class="rounded-full border border-line bg-cream px-5 py-2.5 text-sm text-forest transition-colors hover:border-brass hover:text-brass-600">{c.data.name}</a>
          ))}
          <a href="/areas-we-serve/" class="rounded-full bg-forest px-5 py-2.5 text-sm text-cream transition-colors hover:bg-forest-700">All areas &rarr;</a>
        </div>
      </Container>
    </Section>
  )}

  <!-- FAQ (emits FAQPage JSON-LD) -->
  {d.faqs.length > 0 && (
    <Section variant="cream">
      <Container size="narrow">
        <Eyebrow>Common questions</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">{d.name} STR management — FAQs</h2>
        <div class="mt-8"><FAQ items={d.faqs} /></div>
      </Container>
    </Section>
  )}

  <CTABand heading={`Ready to maximize your ${d.name} property?`} text="Get a free, comps-based rental projection from our local team — no sales pitch, just honest local data." />
</BaseLayout>
