---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import Eyebrow from '@/components/ui/Eyebrow.astro';
import Button from '@/components/ui/Button.astro';
import NeighborhoodCard from '@/components/ui/NeighborhoodCard.astro';
import CTABand from '@/components/ui/CTABand.astro';
import { breadcrumbSchema } from '@/lib/schema';
import { getCollection } from 'astro:content';
import type { ImageKey } from '@/data/images';

const neighborhoods = await getCollection('neighborhoods', (e) => e.data.published && e.data.citySlug === 'atlanta');
neighborhoods.sort((a, b) => {
  const order = ['buckhead','midtown','old-fourth-ward','inman-park','virginia-highland','grant-park','east-atlanta-village','decatur'];
  return order.indexOf(a.data.slug) - order.indexOf(b.data.slug);
});

// Map neighborhood slugs to image keys where known
const imageKeyMap: Record<string, ImageKey> = {
  buckhead: 'nbhdBuckhead',
  midtown: 'nbhdMidtown',
  'old-fourth-ward': 'nbhdOldFourthWard',
  'inman-park': 'nbhdInmanPark',
  decatur: 'nbhdDecatur',
};

const schemas = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Areas We Serve', path: '/areas-we-serve/' },
  ]),
];
---

<BaseLayout
  title="Areas We Serve — Atlanta Neighborhoods | Keystone Stays"
  description="Keystone Stays manages short-term rentals across Atlanta's best neighborhoods — Buckhead, Midtown, Old Fourth Ward, Inman Park, Virginia-Highland, Grant Park, East Atlanta Village, and Decatur."
  schemas={schemas}
>
  <!-- Hero -->
  <Section variant="forest">
    <Container>
      <Eyebrow class="text-brass">Where We Work</Eyebrow>
      <h1 class="mt-3 font-display text-4xl text-cream sm:text-5xl lg:text-6xl">
        Atlanta's Neighborhoods.<br />We Know Every One.
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-cream/80">
        Keystone Stays manages short-term rentals across Atlanta's most in-demand neighborhoods. From Buckhead's luxury corridor to the BeltLine's creative heart, we bring genuine local expertise to every property we manage.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <Button href="/rental-projection/" size="lg">Get my free projection</Button>
        <Button href="/atlanta/" variant="inverse" size="lg">Atlanta city overview</Button>
      </div>
    </Container>
  </Section>

  <!-- Atlanta hub link + intro -->
  <Section variant="cream">
    <Container>
      <div class="max-w-3xl">
        <Eyebrow>Our Market</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">
          One City. Eight Distinct Markets.
        </h2>
        <p class="mt-4 text-lg text-ink/80">
          Atlanta isn't a single short-term rental market — it's a collection of neighborhoods with different guests, different demand drivers, and different pricing dynamics. Buckhead draws corporate travelers and luxury leisure guests. Old Fourth Ward draws BeltLine devotees and weekend wanderers. Decatur draws book festival crowds and Agnes Scott families.
        </p>
        <p class="mt-4 text-ink/80">
          Managing a short-term rental well in Atlanta means knowing the specific neighborhood, not just the metro. That's what Keystone Stays delivers — hyper-local expertise, applied to every property we manage.
        </p>
        <Button href="/atlanta/" variant="secondary" class="mt-6">
          Atlanta market overview &rarr;
        </Button>
      </div>
    </Container>
  </Section>

  <!-- Neighborhood grid -->
  <Section variant="white">
    <Container size="wide">
      <div class="mb-10 text-center">
        <Eyebrow>Atlanta Neighborhoods</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">
          Neighborhoods We Serve
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-ink/70">
          Click any neighborhood to learn about its STR market, demand drivers, and what Keystone Stays delivers for owners there.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {neighborhoods.map((n) => (
          <NeighborhoodCard
            name={n.data.name}
            href={`/atlanta/${n.data.slug}/`}
            imageKey={imageKeyMap[n.data.slug]}
            blurb={n.data.intro.split('.')[0] + '.'}
          />
        ))}
      </div>
    </Container>
  </Section>

  <!-- Why local matters -->
  <Section variant="cream">
    <Container>
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-20 lg:items-center">
        <div>
          <Eyebrow>Why It Matters</Eyebrow>
          <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">
            Local Management Means Better Results
          </h2>
          <p class="mt-4 text-ink/80">
            National STR platforms run algorithms, not relationships. They set prices from national datasets and handle guest issues from call centers that may be in a different time zone. They don't know that Ponce City Market is walking distance from your Old Fourth Ward property. They don't know about the SEC Championship weekend rate spike, or the Inman Park Festival, or the Decatur Book Festival demand surge.
          </p>
          <p class="mt-4 text-ink/80">
            Keystone Stays manages properties across Atlanta's core neighborhoods with genuine local knowledge applied to every decision — pricing, positioning, guest communication, and operations.
          </p>
          <Button href="/services/" variant="secondary" class="mt-6">
            How we manage your property &rarr;
          </Button>
        </div>
        <div class="space-y-6">
          {[
            { title: 'Event-driven pricing', text: 'We track Atlanta\'s full event calendar and adjust nightly rates for every demand spike — sporting events, festivals, conventions, and more.' },
            { title: 'Neighborhood-specific positioning', text: 'Every listing is written for the specific guest who wants that specific neighborhood — not generic Atlanta copy that could apply anywhere.' },
            { title: 'Local vendor networks', text: 'Our cleaning teams, maintenance contacts, and local resources are built specifically for each neighborhood we serve.' },
            { title: 'Compliance guidance', text: 'We know Atlanta\'s STRL requirements and DeKalb County\'s new licensing program — and we help every owner stay current and compliant.' },
          ].map((item) => (
            <div class="flex gap-4">
              <div class="mt-0.5 flex-none">
                <span class="flex h-8 w-8 items-center justify-center rounded-full bg-brass/15">
                  <svg class="h-4 w-4 text-brass-600" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6">
                    <path d="M3 8l3.5 3.5L13 4" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </div>
              <div>
                <h3 class="font-display text-base text-forest">{item.title}</h3>
                <p class="mt-1 text-sm text-ink/70">{item.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </Section>

  <!-- Expanding note -->
  <Section variant="tint">
    <Container>
      <div class="rounded-2xl border border-line bg-white px-8 py-10 text-center">
        <Eyebrow>Growth</Eyebrow>
        <h2 class="mt-3 font-display text-2xl text-forest sm:text-3xl">
          Expanding to More Neighborhoods Soon
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-ink/70">
          We're actively adding new Atlanta-area neighborhoods and plan to expand into additional Georgia markets. If you own a property in an area not listed, reach out — we may already be working nearby.
        </p>
        <Button href="/contact/" variant="secondary" class="mt-6">
          Ask about your area
        </Button>
      </div>
    </Container>
  </Section>

  <CTABand />
</BaseLayout>
