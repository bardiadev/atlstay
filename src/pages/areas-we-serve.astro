---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/ui/PageHero.astro';
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import Eyebrow from '@/components/ui/Eyebrow.astro';
import Button from '@/components/ui/Button.astro';
import NeighborhoodCard from '@/components/ui/NeighborhoodCard.astro';
import CTABand from '@/components/ui/CTABand.astro';
import RelatedReading from '@/components/ui/RelatedReading.astro';
import { breadcrumbSchema } from '@/lib/schema';
import { getCollection } from 'astro:content';
import { assignCardStyles } from '@/lib/cardImage';
import { counties } from '@/data/counties';
import { propertyTypes } from '@/data/propertyTypes';
import { landmarks } from '@/data/landmarks';
import { site } from '@/config/site';

const countyList = counties.filter((c) => c.published).sort((a, b) => a.name.localeCompare(b.name));
const propertyTypeList = propertyTypes.filter((p) => p.published);
const landmarkList = landmarks.filter((l) => l.published);

const neighborhoods = (await getCollection('neighborhoods', (e) => e.data.published && e.data.citySlug === 'atlanta'))
  .sort((a, b) => a.data.name.localeCompare(b.data.name));

const cities = await getCollection('cities', (c) => c.data.published);
const metro = cities.filter((c) => c.data.region === 'metro').sort((a, b) => a.data.name.localeCompare(b.data.name));
const georgia = cities.filter((c) => c.data.region === 'georgia').sort((a, b) => a.data.name.localeCompare(b.data.name));

// Distinct, non-repeating card styling per group (no two nearby cards share a gradient).
const nbhdStyles = assignCardStyles(neighborhoods.map((n) => ({ slug: n.data.slug, region: 'atlanta' })));
const metroStyles = assignCardStyles(metro.map((c) => ({ slug: c.data.slug, region: 'metro' })));
const gaStyles = assignCardStyles(georgia.map((c) => ({ slug: c.data.slug, region: 'georgia' })));

const firstSentence = (s: string) => s.split('. ')[0].replace(/\.$/, '') + '.';

const serviceAreaList = [
  ...cities.map((c) => ({ name: `${c.data.name}, GA`, path: `/${c.data.slug}/` })),
  ...neighborhoods.map((n) => ({ name: `${n.data.name}, Atlanta, GA`, path: `/atlanta/${n.data.slug}/` })),
];
const schemas = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Areas We Serve', path: '/areas-we-serve/' },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Areas served by ATLStay',
    itemListElement: serviceAreaList.map((a, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: a.name,
      url: new URL(a.path, site.domain).href,
    })),
  },
];
---

<BaseLayout
  title="Areas We Serve — Atlanta, Metro Atlanta & Georgia"
  description="ATLStay manages short-term rentals across intown Atlanta, the metro suburbs, and Georgia's top destination markets — from Buckhead and Marietta to Savannah, Blue Ridge, and the coast."
  schemas={schemas}
>
  <PageHero
    title="Short-Term Rental Management Across Georgia"
    subtitle="From intown Atlanta neighborhoods to the metro suburbs and Georgia's top vacation markets — we bring genuine local expertise to every property we manage."
    eyebrow="Areas we serve"
    imageKey="atlantaSkyline"
    breadcrumbs={[{ name: 'Home', path: '/' }, { name: 'Areas We Serve', path: '/areas-we-serve/' }]}
    cta={{ label: 'Get my free rental projection', href: '/rental-projection/' }}
    size="lg"
  />

  <!-- Intown Atlanta neighborhoods -->
  <Section variant="cream">
    <Container size="wide">
      <div class="mb-10 max-w-3xl">
        <Eyebrow>Intown Atlanta</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">Atlanta neighborhoods</h2>
        <p class="mt-4 text-ink/80">
          Atlanta isn't one market — it's a collection of neighborhoods with different guests and demand drivers, and we manage across all of them.
          <a href="/atlanta/" class="text-brass-600 underline underline-offset-2 hover:text-brass">See the Atlanta overview &rarr;</a>
        </p>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {neighborhoods.map((n, i) => (
          <NeighborhoodCard name={n.data.name} href={`/atlanta/${n.data.slug}/`} gradient={nbhdStyles[i].gradient} icon={nbhdStyles[i].icon} blurb={firstSentence(n.data.intro)} />
        ))}
      </div>
    </Container>
  </Section>

  <!-- Metro Atlanta -->
  <Section variant="white">
    <Container size="wide">
      <div class="mb-10 max-w-3xl">
        <Eyebrow>Metro Atlanta</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">Metro Atlanta cities &amp; suburbs</h2>
        <p class="mt-4 text-ink/80">Full-service management for owners across the metro — corporate-travel hubs, family suburbs, and event-driven markets alike.</p>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {metro.map((c, i) => (
          <NeighborhoodCard name={c.data.name} href={`/${c.data.slug}/`} gradient={metroStyles[i].gradient} icon={metroStyles[i].icon} blurb={firstSentence(c.data.intro)} />
        ))}
      </div>
    </Container>
  </Section>

  <!-- Across Georgia -->
  <Section variant="cream">
    <Container size="wide">
      <div class="mb-10 max-w-3xl">
        <Eyebrow>Across Georgia</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">Georgia destination markets</h2>
        <p class="mt-4 text-ink/80">Vacation-rental hotspots across the state — historic cities, mountain towns, lake houses, and the coast.</p>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {georgia.map((c, i) => (
          <NeighborhoodCard name={c.data.name} href={`/${c.data.slug}/`} gradient={gaStyles[i].gradient} icon={gaStyles[i].icon} blurb={firstSentence(c.data.intro)} />
        ))}
      </div>
    </Container>
  </Section>

  <!-- Browse by county -->
  <Section variant="white">
    <Container>
      <div class="mb-8 max-w-3xl">
        <Eyebrow>Browse by county</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">Counties we serve</h2>
        <p class="mt-4 text-ink/80">
          Researching by county? We map every market we manage back to its county for owners working through the city-by-city regulatory landscape.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        {countyList.map((c) => (
          <a href={`/counties/${c.slug}/`} class="rounded-full border border-line bg-cream px-4 py-2 text-sm text-forest transition-colors hover:border-brass hover:text-brass-600">{c.name} County</a>
        ))}
        <a href="/counties/" class="rounded-full bg-forest px-4 py-2 text-sm text-cream transition-colors hover:bg-forest-700">All counties &rarr;</a>
      </div>
    </Container>
  </Section>

  <!-- Browse by property type -->
  <Section variant="cream">
    <Container>
      <div class="mb-8 max-w-3xl">
        <Eyebrow>Browse by property type</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">Property types we manage</h2>
        <p class="mt-4 text-ink/80">
          A cabin in Blue Ridge does not operate the same way as a Buckhead luxury home. We tune management to the asset — explore by property type to see the strategy we run for each.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        {propertyTypeList.map((p) => (
          <a href={`/manage/${p.slug}/`} class="rounded-full border border-line bg-white px-4 py-2 text-sm text-forest transition-colors hover:border-brass hover:text-brass-600">{p.pluralName}</a>
        ))}
        <a href="/manage/" class="rounded-full bg-forest px-4 py-2 text-sm text-cream transition-colors hover:bg-forest-700">All property types &rarr;</a>
      </div>
    </Container>
  </Section>

  <!-- Browse by landmark -->
  <Section variant="white">
    <Container>
      <div class="mb-8 max-w-3xl">
        <Eyebrow>Browse by landmark</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">Management near Atlanta's landmarks</h2>
        <p class="mt-4 text-ink/80">
          Searching by what's nearby? We manage the neighborhoods and cities around Atlanta's biggest demand engines — stadiums, the airport, universities, parks, and the lake.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        {landmarkList.map((l) => (
          <a href={`/near/${l.slug}/`} class="rounded-full border border-line bg-cream px-4 py-2 text-sm text-forest transition-colors hover:border-brass hover:text-brass-600">Near {l.name}</a>
        ))}
        <a href="/near/" class="rounded-full bg-forest px-4 py-2 text-sm text-cream transition-colors hover:bg-forest-700">All landmarks &rarr;</a>
      </div>
    </Container>
  </Section>

  <!-- Why local matters -->
  <Section variant="forest">
    <Container>
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center lg:gap-20">
        <div>
          <Eyebrow class="text-brass">Why it matters</Eyebrow>
          <h2 class="mt-3 font-display text-3xl text-cream sm:text-4xl">Local management means better results</h2>
          <p class="mt-4 text-cream/80">
            National platforms run algorithms, not relationships — pricing from national datasets and handling guests from distant call centers. We manage market by market, with real local knowledge applied to pricing, positioning, guest communication, and operations.
          </p>
          <Button href="/services/" variant="inverse" class="mt-6">How we manage your property &rarr;</Button>
        </div>
        <ul class="space-y-4">
          {[
            "Event-driven pricing tuned to each market's demand calendar",
            'Listings written for the specific guest who wants that specific place',
            'Vetted local cleaning and maintenance networks in every market',
            'We track local STR rules — permits, taxes, requirements — so you stay compliant',
          ].map((item) => (
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 flex-none text-brass" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.3 3.3 6.8-6.8a1 1 0 0 1 1.4 0z" clip-rule="evenodd" /></svg>
              <span class="text-cream/90">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </Container>
  </Section>

  <!-- Expanding note -->
  <Section variant="tint">
    <Container>
      <div class="rounded-2xl border border-line bg-white px-8 py-10 text-center">
        <Eyebrow>Growing</Eyebrow>
        <h2 class="mt-3 font-display text-2xl text-forest sm:text-3xl">Don't see your area?</h2>
        <p class="mx-auto mt-4 max-w-xl text-ink/70">
          We're continually adding markets across Georgia and the Southeast. If you own a property in an area not listed, reach out — we may already be working nearby.
        </p>
        <Button href="/contact/" variant="secondary" class="mt-6">Ask about your area</Button>
      </div>
    </Container>
  </Section>

  <RelatedReading
    variant="white"
    heading="Helpful guides for Atlanta owners"
    items={[
      { title: "Best Atlanta Neighborhoods for Airbnb", desc: "A tour of the areas with the strongest short-term rental demand across the city.", href: "/resources/best-atlanta-neighborhoods-for-airbnb/" },
      { title: "Atlanta Short-Term Rental Regulations", desc: "Permits, licensing, and taxes to verify before you list your property.", href: "/resources/atlanta-short-term-rental-regulations/" },
      { title: "Airbnb vs. Long-Term Rental in Atlanta", desc: "Which earns more for your property — and how to decide what fits your goals.", href: "/resources/airbnb-vs-long-term-rental-atlanta/" },
    ]}
  />

  <CTABand />
</BaseLayout>
