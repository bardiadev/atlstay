---
// On-site search. Backs the WebSite SearchAction sitelinks searchbox in
// Google SERPs (the urlTemplate in src/lib/schema.ts points here). Indexes
// every published city, neighbourhood, and resource at build time and ships
// a tiny client-side filter — no API, works as a static page.
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import Eyebrow from '@/components/ui/Eyebrow.astro';
import { getCollection } from 'astro:content';

const [cities, neighborhoods, resources] = await Promise.all([
  getCollection('cities', (c) => c.data.published),
  getCollection('neighborhoods', (n) => n.data.published),
  getCollection('resources', (r) => !r.data.draft),
]);

const items = [
  ...cities.map((c) => ({
    type: 'Market',
    title: `${c.data.name}, ${c.data.state}`,
    description: c.data.description,
    href: `/${c.data.slug}/`,
  })),
  ...neighborhoods.map((n) => ({
    type: 'Atlanta neighborhood',
    title: `${n.data.name} — Atlanta`,
    description: n.data.description,
    href: `/${n.data.citySlug}/${n.data.slug}/`,
  })),
  ...resources.map((r) => ({
    type: r.data.category,
    title: r.data.title,
    description: r.data.description,
    href: `/resources/${r.id}/`,
  })),
];

const indexCount = items.length;
---
<BaseLayout
  title="Search ATLStay"
  description="Search every ATLStay market, Atlanta neighborhood, and owner guide."
  noindex
>
  <Section variant="cream">
    <Container>
      <div class="mx-auto max-w-3xl">
        <Eyebrow>Search</Eyebrow>
        <h1 class="mt-2 font-display text-3xl text-forest sm:text-4xl">Search ATLStay</h1>
        <p class="mt-3 text-ink/75">Find any market, Atlanta neighborhood, or owner guide.</p>
        <form id="search-form" class="mt-6" role="search" onsubmit="return false;">
          <label class="block">
            <span class="sr-only">Search query</span>
            <input
              id="search-input"
              name="q"
              type="search"
              autocomplete="off"
              placeholder="e.g. Buckhead, Savannah, dynamic pricing, regulations…"
              class="w-full rounded-lg border border-line bg-white px-4 py-3 text-base text-ink shadow-sm focus:border-brass focus:outline-none focus:ring-2 focus:ring-brass/40"
            />
          </label>
        </form>
        <p id="search-meta" class="mt-3 text-sm text-stone">Start typing to search across {indexCount} pages.</p>
      </div>

      <div id="search-results" class="mx-auto mt-8 grid max-w-6xl gap-4 sm:grid-cols-2 lg:grid-cols-3"></div>
    </Container>
  </Section>
</BaseLayout>

<script type="application/json" id="search-data" set:html={JSON.stringify(items)}></script>
<script is:inline>
  (() => {
    const dataEl = document.getElementById('search-data');
    const input = document.getElementById('search-input');
    const meta = document.getElementById('search-meta');
    const grid = document.getElementById('search-results');
    if (!dataEl || !input || !meta || !grid) return;
    const items = JSON.parse(dataEl.textContent || '[]');
    const totalCount = items.length;

    const escapeRe = (s) => s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    const escapeHtml = (s) =>
      s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));

    const getQ = () => new URLSearchParams(location.search).get('q') ?? '';
    const setQ = (q) => {
      const u = new URL(location.href);
      if (q) u.searchParams.set('q', q);
      else u.searchParams.delete('q');
      history.replaceState({}, '', u);
    };

    function render(q) {
      const needle = q.trim().toLowerCase();
      if (!needle) {
        meta.textContent = 'Start typing to search across ' + totalCount + ' pages.';
        grid.innerHTML = '';
        return;
      }
      const re = new RegExp(escapeRe(needle), 'g');
      const scored = [];
      for (const i of items) {
        const hay = (i.title + ' ' + i.description + ' ' + i.type).toLowerCase();
        if (!hay.includes(needle)) continue;
        const titleHits = (i.title.toLowerCase().match(re) || []).length;
        const totalHits = (hay.match(re) || []).length;
        scored.push({ i, score: titleHits * 3 + totalHits });
      }
      scored.sort((a, b) => b.score - a.score);
      const matches = scored.slice(0, 60).map((x) => x.i);
      meta.textContent =
        matches.length + ' result' + (matches.length === 1 ? '' : 's') + ' for "' + q + '"';
      grid.innerHTML = matches
        .map(
          (m) =>
            '<a href="' + escapeHtml(m.href) +
            '" class="block rounded-2xl border border-line bg-white p-5 transition-all hover:-translate-y-0.5 hover:border-brass/60 hover:shadow-md">' +
            '<span class="text-xs font-semibold uppercase tracking-[0.18em] text-brass-600">' + escapeHtml(m.type) + '</span>' +
            '<h2 class="mt-2 font-display text-lg text-forest leading-snug">' + escapeHtml(m.title) + '</h2>' +
            '<p class="mt-1.5 line-clamp-3 text-sm text-ink/75">' + escapeHtml(m.description) + '</p>' +
            '</a>'
        )
        .join('');
    }

    input.addEventListener('input', () => {
      setQ(input.value);
      render(input.value);
    });
    input.value = getQ();
    if (input.value) render(input.value);
    input.focus();
  })();
</script>
