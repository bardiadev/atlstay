---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/ui/PageHero.astro';
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import Eyebrow from '@/components/ui/Eyebrow.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import CTABand from '@/components/ui/CTABand.astro';
import { site } from '@/config/site';
import { breadcrumbSchema } from '@/lib/schema';

const schemas = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Contact', path: '/contact/' },
  ]),
];

// Lead delivery routes through src/lib/leads.ts (Web3Forms when a key is set,
// otherwise a graceful client-side success). See site.forms in config.
const serviceAreaNeighborhoods = [
  'Buckhead', 'Midtown', 'Old Fourth Ward', 'Inman Park',
  'Virginia-Highland', 'Grant Park', 'East Atlanta Village', 'Decatur',
  'Candler Park', 'Cabbagetown', 'Reynoldstown', 'West Midtown',
  'Downtown Atlanta', 'Poncey-Highland', 'Ormewood Park', 'East Lake',
];
---

<BaseLayout
  title="Contact ATLStay — Atlanta STR Management"
  description={`Reach the ATLStay team at ${site.contact.phone} or ${site.contact.email}. We manage short-term rentals across Atlanta and metro neighborhoods. No sales pitch — just honest answers.`}
  schemas={schemas}
>

  <PageHero
    title="Contact ATLStay — Atlanta STR Management"
    subtitle="Ready to get started or just have questions? We're easy to reach and we don't do sales calls — just honest conversations about your property."
    eyebrow="GET IN TOUCH"
    imageKey="atlantaSkyline"
    breadcrumbs={[{ name: 'Home', path: '/' }, { name: 'Contact', path: '/contact/' }]}
    cta={{ label: 'Get my free projection', href: '/rental-projection/' }}
    size="sm"
  />

  <!-- ─── CONTACT DETAILS + FORM ─── -->
  <Section variant="white">
    <Container>
      <div class="grid gap-12 lg:grid-cols-[1fr_1.5fr] lg:gap-20">

        <!-- Contact details column -->
        <div>
          <Eyebrow>Direct contact</Eyebrow>
          <h2 class="mt-3 font-display text-3xl text-forest">
            Real people. Real answers.
          </h2>
          <p class="mt-4 text-ink/75">
            No chatbot, no ticket system, no hold music. We respond to every inquiry personally — usually the same day.
          </p>

          <div class="mt-8 space-y-6">

            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 flex-none items-center justify-center rounded-xl bg-forest-50">
                <svg class="h-5 w-5 text-forest" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path d="M2.5 6.5C2.5 13 7 17.5 13.5 17.5l2-.4c.5-.1.9-.5.9-1v-2.3c0-.5-.3-.9-.8-1l-1.7-.5a1 1 0 0 0-1 .3L12 13.9c-1.5-.8-3.1-2.4-3.9-3.9l.9-.9a1 1 0 0 0 .3-1L8.8 6.3a1 1 0 0 0-1-.8H5.5c-.5 0-.9.4-1 .9l-.4 2 1.4-.9z" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-stone">Phone</p>
                <a href={site.contact.phoneHref} class="mt-1 block font-display text-xl text-forest hover:text-brass-600 transition-colors">
                  {site.contact.phone}
                </a>
                <p class="mt-1 text-sm text-stone">Call or text — we check both</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 flex-none items-center justify-center rounded-xl bg-forest-50">
                <svg class="h-5 w-5 text-forest" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path d="M3 5h14a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1zm0 0 7 7 7-7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-stone">Email</p>
                <a href={`mailto:${site.contact.email}`} class="mt-1 block font-display text-xl text-forest hover:text-brass-600 transition-colors">
                  {site.contact.email}
                </a>
                <p class="mt-1 text-sm text-stone">We respond same day on weekdays</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 flex-none items-center justify-center rounded-xl bg-forest-50">
                <svg class="h-5 w-5 text-forest" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path d="M10 2C6.7 2 4 4.7 4 8c0 4.5 6 10 6 10s6-5.5 6-10c0-3.3-2.7-6-6-6zm0 8a2 2 0 1 1 0-4 2 2 0 0 1 0 4z" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-stone">Service area</p>
                <p class="mt-1 font-display text-xl text-forest">{site.contact.address.city}, {site.contact.address.region}</p>
                <p class="mt-1 text-sm text-stone">Metro Atlanta and surrounding neighborhoods</p>
              </div>
            </div>

          </div>

          <!-- Primary action -->
          <div class="mt-10 rounded-2xl bg-brass-50 p-6">
            <h3 class="font-display text-lg text-forest">Want a rental projection first?</h3>
            <p class="mt-2 text-sm text-ink/70">
              Start with our free, no-obligation projection. It's the fastest way to understand what your property could earn — and the best first conversation we can have.
            </p>
            <Button href="/rental-projection/" class="mt-5" size="md">
              Get my free projection
            </Button>
          </div>

          <!-- Service area list -->
          <div class="mt-8">
            <h3 class="font-display text-base text-forest">Neighborhoods we serve</h3>
            <ul class="mt-3 grid grid-cols-2 gap-x-4 gap-y-1.5">
              {serviceAreaNeighborhoods.map((nbhd) => (
                <li class="text-sm text-ink/70">{nbhd}</li>
              ))}
            </ul>
            <p class="mt-3 text-xs text-stone">Not on the list? Reach out — we may serve your area.</p>
          </div>
        </div>

        <!-- Contact form column -->
        <div>
          <Eyebrow>Send us a message</Eyebrow>
          <h2 class="mt-3 font-display text-2xl text-forest">
            What's on your mind?
          </h2>
          <p class="mt-2 text-ink/75">We read every message personally and respond with honest answers — not a brochure.</p>

          <form
            id="contact-form"
            class="mt-8 space-y-5"
            method="POST"
            novalidate
          >
            <!-- Honeypot anti-spam field — hidden from real users -->
            <div aria-hidden="true" class="absolute left-[-9999px] top-0 h-0 overflow-hidden">
              <label for="contact-website">Website (leave blank)</label>
              <input
                type="text"
                id="contact-website"
                name="website"
                tabindex="-1"
                autocomplete="off"
              />
            </div>

            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <label for="contact-name" class="block text-sm font-medium text-forest">
                  Your name <span class="text-brass-600" aria-label="required">*</span>
                </label>
                <input
                  type="text"
                  id="contact-name"
                  name="name"
                  required
                  autocomplete="name"
                  class="mt-1.5 block w-full rounded-xl border border-line bg-white px-4 py-3 text-ink placeholder-stone/60 shadow-sm transition-colors focus:border-forest focus:outline-none focus:ring-2 focus:ring-forest/20"
                  placeholder="Jane Smith"
                />
              </div>
              <div>
                <label for="contact-email" class="block text-sm font-medium text-forest">
                  Email address <span class="text-brass-600" aria-label="required">*</span>
                </label>
                <input
                  type="email"
                  id="contact-email"
                  name="email"
                  required
                  autocomplete="email"
                  class="mt-1.5 block w-full rounded-xl border border-line bg-white px-4 py-3 text-ink placeholder-stone/60 shadow-sm transition-colors focus:border-forest focus:outline-none focus:ring-2 focus:ring-forest/20"
                  placeholder="jane@example.com"
                />
              </div>
            </div>

            <div>
              <label for="contact-phone" class="block text-sm font-medium text-forest">
                Phone number <span class="text-stone font-normal">(optional)</span>
              </label>
              <input
                type="tel"
                id="contact-phone"
                name="phone"
                autocomplete="tel"
                class="mt-1.5 block w-full rounded-xl border border-line bg-white px-4 py-3 text-ink placeholder-stone/60 shadow-sm transition-colors focus:border-forest focus:outline-none focus:ring-2 focus:ring-forest/20"
                placeholder="(404) 555-0000"
              />
            </div>

            <div>
              <label for="contact-message" class="block text-sm font-medium text-forest">
                How can we help? <span class="text-brass-600" aria-label="required">*</span>
              </label>
              <textarea
                id="contact-message"
                name="message"
                required
                rows="5"
                class="mt-1.5 block w-full resize-none rounded-xl border border-line bg-white px-4 py-3 text-ink placeholder-stone/60 shadow-sm transition-colors focus:border-forest focus:outline-none focus:ring-2 focus:ring-forest/20"
                placeholder="Tell us about your property or ask us anything — we give real answers."
              ></textarea>
            </div>

            <div class="flex items-start gap-3 pt-1">
              <Button type="submit" size="lg">Send message</Button>
              <p class="text-xs text-stone self-center">We respond same day, most weekdays.</p>
            </div>
          </form>

          <!-- Success / error state (handled by inline script below) -->
          <div id="contact-success" class="hidden mt-8 rounded-2xl bg-forest-50 p-6">
            <h3 class="font-display text-lg text-forest">Message received. Thank you.</h3>
            <p class="mt-2 text-sm text-ink/75">We'll get back to you within one business day. No sales call unless you want one.</p>
          </div>
          <div id="contact-error" class="hidden mt-4 rounded-xl bg-red-50 p-4">
            <p class="text-sm text-red-700">Something went wrong sending your message. Please email us directly at <a href={`mailto:${site.contact.email}`} class="underline">{site.contact.email}</a> or call <a href={site.contact.phoneHref} class="underline">{site.contact.phone}</a>.</p>
          </div>
        </div>

      </div>
    </Container>
  </Section>

  <!-- ─── LOCAL BUSINESS EMPHASIS ─── -->
  <Section variant="cream">
    <Container>
      <div class="grid gap-8 sm:grid-cols-3">
        <Card>
          <h3 class="font-display text-lg text-forest">Atlanta-based</h3>
          <p class="mt-2 text-sm text-ink/70">We're not a national brand with an Atlanta branch. We are an Atlanta company — managing properties in neighborhoods we know personally.</p>
        </Card>
        <Card>
          <h3 class="font-display text-lg text-forest">Owner-focused</h3>
          <p class="mt-2 text-sm text-ink/70">Every decision we make is oriented toward owner outcomes. You're not a property number in our system — you're a partner we're genuinely invested in.</p>
        </Card>
        <Card>
          <h3 class="font-display text-lg text-forest">No pressure, ever</h3>
          <p class="mt-2 text-sm text-ink/70">We hate pushy sales calls. Ask us anything — about our process, our fee, our results — and you'll get a straight answer, not a pitch.</p>
        </Card>
      </div>
    </Container>
  </Section>

  <!-- ─── CTA BAND ─── -->
  <CTABand
    heading="Rather start with a projection?"
    text="Our free rental projection is the best first step — a custom, comps-based estimate of what your Atlanta home could earn, built by a real person."
    ctaLabel="Get my free projection"
    ctaHref="/rental-projection/"
  />

</BaseLayout>

<!-- Lead delivery via the shared helper (Web3Forms when configured). -->
<script>
  import { sendLead } from '../lib/leads';

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successEl = document.getElementById('contact-success');
  const errorEl = document.getElementById('contact-error');
  const submitBtn = form?.querySelector<HTMLButtonElement>('button[type="submit"]');
  const loadedAt = Date.now();

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (errorEl) errorEl.classList.add('hidden');

      // Bot defenses: honeypot + implausibly fast submit. Either → silent stop.
      const honeypot = form.querySelector<HTMLInputElement>('input[name="website"]');
      if ((honeypot && honeypot.value) || Date.now() - loadedAt < 3000) {
        form.style.display = 'none';
        if (successEl) successEl.classList.remove('hidden');
        return;
      }

      const fd = new FormData(form);
      const name = String(fd.get('name') || '').trim();
      const email = String(fd.get('email') || '').trim();
      const message = String(fd.get('message') || '').trim();
      if (!name || !email || !message) {
        if (errorEl) errorEl.classList.remove('hidden');
        return;
      }

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending…';
      }

      const result = await sendLead(
        {
          name,
          email,
          phone: String(fd.get('phone') || ''),
          message,
        },
        { subject: `New contact message — ${name}`, formName: 'ATLStay Contact Form' },
      );

      if (result.ok) {
        form.style.display = 'none';
        if (successEl) successEl.classList.remove('hidden');
      } else {
        if (errorEl) errorEl.classList.remove('hidden');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send message';
        }
      }
    });
  }
</script>
