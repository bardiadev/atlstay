---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/ui/PageHero.astro';
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import Eyebrow from '@/components/ui/Eyebrow.astro';
import NeighborhoodCard from '@/components/ui/NeighborhoodCard.astro';
import CTABand from '@/components/ui/CTABand.astro';
import { breadcrumbSchema, itemListSchema } from '@/lib/schema';
import { assignCardStyles } from '@/lib/cardImage';
import { propertyTypes } from '@/data/propertyTypes';

const published = propertyTypes.filter((p) => p.published);
const styles = assignCardStyles(
  published.map((p) => ({ slug: p.slug, region: 'metro' as const })),
);

const schemas = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Services', path: '/services/' },
    { name: 'By property type', path: '/manage/' },
  ]),
  itemListSchema({
    name: 'Short-term rental management by property type',
    items: published.map((p) => ({
      name: p.pluralName,
      path: `/manage/${p.slug}/`,
      description: p.tagline,
    })),
  }),
];
---

<BaseLayout
  title="STR Management by Property Type — Cabins, Lake Houses, Luxury, Condos"
  description="ATLStay manages short-term rentals across every property type — cabins, lake houses, luxury homes, condos, townhomes, ADUs, beach houses, and corporate housing."
  schemas={schemas}
>
  <PageHero
    title="Short-Term Rental Management by Property Type"
    subtitle="Every property type brings its own demand, operational realities, and guest profile. We manage cabins, lake houses, luxury homes, condos, townhomes, ADUs, beach houses, and corporate housing across Atlanta and Georgia."
    eyebrow="By property type"
    imageKey="atlantaSkyline"
    breadcrumbs={[
      { name: 'Home', path: '/' },
      { name: 'Services', path: '/services/' },
      { name: 'By property type', path: '/manage/' },
    ]}
    cta={{ label: 'Get my free rental projection', href: '/rental-projection/' }}
    secondaryCta={{ label: 'See all services', href: '/services/' }}
    size="lg"
  />

  <Section variant="cream">
    <Container size="wide">
      <div class="mb-10 max-w-3xl">
        <Eyebrow>Specialised management</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">Property types we manage</h2>
        <p class="mt-4 text-ink/80">
          A cabin in Blue Ridge does not operate the same way as a Buckhead luxury home. Different property types bring different guests, different operational rhythms, and different ways to maximize revenue. We tune the strategy to the asset.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {published.map((p, i) => (
          <NeighborhoodCard
            name={p.pluralName}
            href={`/manage/${p.slug}/`}
            gradient={styles[i].gradient}
            icon={styles[i].icon}
            blurb={p.tagline}
          />
        ))}
      </div>
    </Container>
  </Section>

  <CTABand />
</BaseLayout>
