---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/ui/PageHero.astro';
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import Eyebrow from '@/components/ui/Eyebrow.astro';
import Button from '@/components/ui/Button.astro';
import NeighborhoodCard from '@/components/ui/NeighborhoodCard.astro';
import FAQ from '@/components/ui/FAQ.astro';
import CTABand from '@/components/ui/CTABand.astro';
import { breadcrumbSchema, serviceSchema, itemListSchema } from '@/lib/schema';
import { assignCardStyles } from '@/lib/cardImage';
import { propertyTypes } from '@/data/propertyTypes';
import { site } from '@/config/site';

export async function getStaticPaths() {
  return propertyTypes
    .filter((p) => p.published)
    .map((p) => ({ params: { type: p.slug }, props: { type: p } }));
}

const { type } = Astro.props;

const [allCities, allNeighborhoods] = await Promise.all([
  getCollection('cities', (c) => c.data.published),
  getCollection('neighborhoods', (n) => n.data.published),
]);

const citiesIn = type.marketCities
  .map((slug) => allCities.find((c) => c.data.slug === slug))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));
const neighborhoodsIn = (type.marketNeighborhoods ?? [])
  .map((slug) => allNeighborhoods.find((n) => n.data.slug === slug))
  .filter((n): n is NonNullable<typeof n> => Boolean(n));

// Merge for the linked grid (cards), tagged with kind so we know how to link.
const marketCards = [
  ...citiesIn.map((c) => ({
    kind: 'city' as const,
    name: c.data.name,
    href: `/${c.data.slug}/`,
    slug: c.data.slug,
    region: c.data.region,
    blurb: c.data.intro.split('.')[0] + '.',
  })),
  ...neighborhoodsIn.map((n) => ({
    kind: 'neighborhood' as const,
    name: `${n.data.name}, Atlanta`,
    href: `/${n.data.citySlug}/${n.data.slug}/`,
    slug: n.data.slug,
    region: 'atlanta' as const,
    blurb: n.data.intro.split('.')[0] + '.',
  })),
];

const styles = assignCardStyles(marketCards.map((m) => ({ slug: m.slug, region: m.region })));

const heading = `${type.headlineKeyword} — Atlanta & Georgia`;
const seoTitle = `${type.name} STR Management, Atlanta & Georgia`;
const seoDesc =
  `${type.intro.split('.')[0]}. ATLStay handles full-service ${type.name.toLowerCase()} rental management across ${type.marketLabel}.`.slice(
    0,
    160,
  );

const schemas = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Services', path: '/services/' },
    { name: 'By property type', path: '/manage/' },
    { name: type.pluralName, path: `/manage/${type.slug}/` },
  ]),
  serviceSchema({
    name: heading,
    description: type.intro,
    serviceType: `${type.name} short-term rental management`,
  }),
  ...(marketCards.length
    ? [
        itemListSchema({
          name: `${type.pluralName} markets ATLStay manages in Georgia`,
          items: marketCards.map((m) => ({
            name: m.name,
            path: m.href,
            description: m.blurb,
          })),
        }),
      ]
    : []),
];
---

<BaseLayout title={seoTitle} description={seoDesc} schemas={schemas}>
  <PageHero
    title={heading}
    subtitle={type.intro}
    eyebrow={`Property type · ${type.tagline}`}
    imageKey="atlantaSkyline"
    breadcrumbs={[
      { name: 'Home', path: '/' },
      { name: 'Services', path: '/services/' },
      { name: 'By property type', path: '/manage/' },
      { name: type.pluralName, path: `/manage/${type.slug}/` },
    ]}
    cta={{ label: 'Get my free rental projection', href: '/rental-projection/' }}
    secondaryCta={{ label: 'See all services', href: '/services/' }}
    size="lg"
  />

  <!-- What we deliver -->
  <Section variant="cream">
    <Container>
      <div class="grid gap-12 lg:grid-cols-2 lg:items-start lg:gap-20">
        <div>
          <Eyebrow>What we deliver</Eyebrow>
          <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">Full-service {type.name.toLowerCase()} management</h2>
          <p data-speakable class="mt-4 text-ink/80">
            ATLStay handles every part of a {type.name.toLowerCase()} short-term rental — listing creation and photography, dynamic pricing, 24/7 guest communication, cleaning, turnovers, and the {type.name.toLowerCase()}-specific operational layer. One transparent rate, {site.pricing.rateNote}.
          </p>
          <Button href="/services/" variant="secondary" class="mt-6">See all services &rarr;</Button>
        </div>
        <div class="rounded-2xl border border-line bg-white p-8">
          <h3 class="font-display text-lg text-forest">Who books {type.pluralName.toLowerCase()}</h3>
          <p data-speakable class="mt-4 text-ink/80">{type.demand}</p>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Operational considerations specific to this property type -->
  <Section variant="white">
    <Container size="narrow">
      <Eyebrow>{type.name} operations</Eyebrow>
      <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">What {type.name.toLowerCase()} management actually involves</h2>
      <p data-speakable class="mt-4 text-ink/80">{type.operations}</p>
    </Container>
  </Section>

  <!-- Markets where this property type concentrates -->
  {marketCards.length > 0 && (
    <Section variant="cream">
      <Container size="wide">
        <div class="mb-10 text-center">
          <Eyebrow>{type.marketLabel}</Eyebrow>
          <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">Markets where {type.name.toLowerCase()} STR works best</h2>
          <p class="mx-auto mt-4 max-w-2xl text-ink/70">
            We manage {type.pluralName.toLowerCase()} across these Georgia markets. Each one has a distinct demand pattern — explore the local detail or get a projection for your specific address.
          </p>
        </div>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {marketCards.map((m, i) => (
            <NeighborhoodCard
              name={m.name}
              href={m.href}
              gradient={styles[i].gradient}
              icon={styles[i].icon}
              blurb={m.blurb}
            />
          ))}
        </div>
      </Container>
    </Section>
  )}

  <!-- FAQ -->
  {type.faqs.length > 0 && (
    <Section variant="white">
      <Container size="narrow">
        <Eyebrow>Common questions</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">{type.name} STR management — FAQs</h2>
        <div class="mt-8"><FAQ items={type.faqs} /></div>
      </Container>
    </Section>
  )}

  <CTABand
    heading={`Ready to maximize your ${type.name.toLowerCase()}?`}
    text="Get a free, comps-based rental projection from our local team."
  />
</BaseLayout>
