---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/ui/PageHero.astro';
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import Eyebrow from '@/components/ui/Eyebrow.astro';
import NeighborhoodCard from '@/components/ui/NeighborhoodCard.astro';
import CTABand from '@/components/ui/CTABand.astro';
import { breadcrumbSchema, itemListSchema } from '@/lib/schema';
import { assignCardStyles } from '@/lib/cardImage';
import { landmarks } from '@/data/landmarks';

const published = landmarks.filter((l) => l.published);
const styles = assignCardStyles(published.map((l) => ({ slug: l.slug, region: 'atlanta' as const })));

const schemas = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Near Atlanta Landmarks', path: '/near/' },
  ]),
  itemListSchema({
    name: 'Atlanta landmarks ATLStay manages rentals near',
    items: published.map((l) => ({ name: l.name, path: `/near/${l.slug}/`, description: l.tagline })),
  }),
];
---

<BaseLayout
  title="Airbnb Management Near Atlanta Landmarks — Stadiums & Airport"
  description="Short-term rental management near Atlanta's biggest landmarks — Mercedes-Benz Stadium, Hartsfield-Jackson, Truist Park, Piedmont Park, Emory, Lake Lanier, the BeltLine and more."
  schemas={schemas}
>
  <PageHero
    title="Short-Term Rental Management Near Atlanta's Landmarks"
    subtitle="Stadiums, the airport, universities, parks, and the lake — the demand engines that drive bookings. We manage the neighborhoods and cities around each one."
    eyebrow="Near Atlanta landmarks"
    imageKey="atlantaSkyline"
    breadcrumbs={[
      { name: 'Home', path: '/' },
      { name: 'Near Atlanta Landmarks', path: '/near/' },
    ]}
    cta={{ label: 'Get my free rental projection', href: '/rental-projection/' }}
    secondaryCta={{ label: 'All areas we serve', href: '/areas-we-serve/' }}
    size="lg"
  />

  <Section variant="cream">
    <Container size="wide">
      <div class="mb-10 max-w-3xl">
        <Eyebrow>Demand engines</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">Landmarks that drive bookings</h2>
        <p class="mt-4 text-ink/80">
          Some of the strongest short-term-rental demand in Atlanta clusters around its landmarks — game-day weekends, festival nights, airport layovers, campus visits, and lake summers. Explore management near each one.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {published.map((l, i) => (
          <NeighborhoodCard name={l.name} href={`/near/${l.slug}/`} gradient={styles[i].gradient} icon={styles[i].icon} blurb={l.tagline} />
        ))}
      </div>
    </Container>
  </Section>

  <CTABand />
</BaseLayout>
