---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/ui/PageHero.astro';
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import Eyebrow from '@/components/ui/Eyebrow.astro';
import Button from '@/components/ui/Button.astro';
import NeighborhoodCard from '@/components/ui/NeighborhoodCard.astro';
import FAQ from '@/components/ui/FAQ.astro';
import CTABand from '@/components/ui/CTABand.astro';
import { breadcrumbSchema, serviceSchema, itemListSchema } from '@/lib/schema';
import { assignCardStyles } from '@/lib/cardImage';
import { landmarks } from '@/data/landmarks';
import { site } from '@/config/site';

export async function getStaticPaths() {
  return landmarks
    .filter((l) => l.published)
    .map((l) => ({ params: { landmark: l.slug }, props: { landmark: l } }));
}

const { landmark } = Astro.props;
const styles = assignCardStyles(landmark.nearby.map((n) => ({ slug: n.href, region: 'metro' })));

const heading = `Airbnb & Short-Term Rental Management Near ${landmark.name}`;
const seoTitle = `Airbnb Management Near ${landmark.shortName ?? landmark.name}`;
const seoDesc = `${landmark.intro.split('. ')[0]}. ATLStay manages short-term rentals near ${landmark.name} — call ${site.contact.phone}.`.slice(0, 160);

const schemas = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Near Atlanta Landmarks', path: '/near/' },
    { name: landmark.name, path: `/near/${landmark.slug}/` },
  ]),
  serviceSchema({
    name: heading,
    description: landmark.intro,
    serviceType: 'Short-term rental management',
  }),
  itemListSchema({
    name: `Areas ATLStay manages near ${landmark.name}`,
    items: landmark.nearby.map((n) => ({ name: n.name, path: n.href })),
  }),
];
---

<BaseLayout title={seoTitle} description={seoDesc} schemas={schemas}>
  <PageHero
    title={heading}
    subtitle={landmark.intro}
    eyebrow={`Near ${landmark.name} · ${landmark.kind}`}
    imageKey="atlantaSkyline"
    breadcrumbs={[
      { name: 'Home', path: '/' },
      { name: 'Near Atlanta Landmarks', path: '/near/' },
      { name: landmark.name, path: `/near/${landmark.slug}/` },
    ]}
    cta={{ label: 'Get my free rental projection', href: '/rental-projection/' }}
    secondaryCta={{ label: `Call ${site.contact.phone}`, href: site.contact.phoneHref }}
    size="lg"
  />

  <!-- Demand -->
  <Section variant="cream">
    <Container>
      <div class="grid gap-12 lg:grid-cols-2 lg:items-start lg:gap-20">
        <div>
          <Eyebrow>Why guests book here</Eyebrow>
          <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">Demand near {landmark.name}</h2>
          <p data-speakable class="mt-4 text-ink/80">{landmark.demand}</p>
          <div class="mt-6 flex flex-col gap-3 sm:flex-row">
            <Button href="/rental-projection/" size="lg">Get my free projection</Button>
            <a href={site.contact.phoneHref} class="inline-flex items-center justify-center gap-2 rounded-full border border-forest px-6 py-3 text-sm font-semibold text-forest transition-colors hover:bg-white">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24c1.14.38 2.35.58 3.6.58a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.58 3.6a1 1 0 0 1-.24 1z"/></svg>
              Call {site.contact.phone}
            </a>
          </div>
        </div>
        <div class="rounded-2xl border border-line bg-white p-8">
          <h3 class="font-display text-lg text-forest">What we handle</h3>
          <p data-speakable class="mt-4 text-ink/80">
            ATLStay manages every part of a short-term rental near {landmark.name} — listing and photography, {landmark.kind.toLowerCase()}-aware dynamic pricing, 24/7 guest communication, cleaning, and turnovers. One transparent rate, {site.pricing.rateNote}.
          </p>
          <Button href="/services/" variant="secondary" class="mt-6">See all services &rarr;</Button>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Nearby areas we manage -->
  {landmark.nearby.length > 0 && (
    <Section variant="white">
      <Container size="wide">
        <div class="mb-10 text-center">
          <Eyebrow>Areas we manage</Eyebrow>
          <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">Neighborhoods &amp; cities near {landmark.name}</h2>
          <p class="mx-auto mt-4 max-w-2xl text-ink/70">We manage full-service short-term rentals across the areas closest to {landmark.name}. Explore the local detail or get a projection for your exact address.</p>
        </div>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {landmark.nearby.map((n, i) => (
            <NeighborhoodCard name={n.name} href={n.href} gradient={styles[i].gradient} icon={styles[i].icon} />
          ))}
        </div>
      </Container>
    </Section>
  )}

  <!-- FAQ -->
  {landmark.faqs.length > 0 && (
    <Section variant="cream">
      <Container size="narrow">
        <Eyebrow>Common questions</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">Airbnb management near {landmark.name} — FAQs</h2>
        <div class="mt-8"><FAQ items={landmark.faqs} /></div>
      </Container>
    </Section>
  )}

  <CTABand
    heading={`Own a property near ${landmark.name}?`}
    text="Get a free, comps-based rental projection from our local team — or just call and ask us anything."
  />
</BaseLayout>
