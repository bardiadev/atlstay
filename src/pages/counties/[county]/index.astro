---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/ui/PageHero.astro';
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import Eyebrow from '@/components/ui/Eyebrow.astro';
import Button from '@/components/ui/Button.astro';
import NeighborhoodCard from '@/components/ui/NeighborhoodCard.astro';
import FAQ from '@/components/ui/FAQ.astro';
import CTABand from '@/components/ui/CTABand.astro';
import { breadcrumbSchema, serviceSchema, itemListSchema } from '@/lib/schema';
import { assignCardStyles } from '@/lib/cardImage';
import { counties } from '@/data/counties';
import { site } from '@/config/site';

export async function getStaticPaths() {
  return counties
    .filter((c) => c.published)
    .map((c) => ({ params: { county: c.slug }, props: { county: c } }));
}

const { county } = Astro.props;

// Wire to the cities collection so the linked grid is automatically in sync.
const allCities = await getCollection('cities', (c) => c.data.published);
const citiesInCounty = county.cities
  .map((slug) => allCities.find((c) => c.data.slug === slug))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));

const styles = assignCardStyles(
  citiesInCounty.map((c) => ({ slug: c.data.slug, region: c.data.region })),
);

const heading = `Vacation Rental & Airbnb Management in ${county.name} County, ${county.state}`;
const seoTitle = `${county.name} County Airbnb Management, GA`;
const seoDesc =
  `${county.intro.split('.')[0]}. ATLStay handles full-service short-term rental management across ${county.name} County.`.slice(
    0,
    160,
  );

const schemas = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Areas We Serve', path: '/areas-we-serve/' },
    { name: 'Counties', path: '/counties/' },
    { name: `${county.name} County`, path: `/counties/${county.slug}/` },
  ]),
  serviceSchema({
    name: heading,
    description: county.intro,
    area: {
      name: `${county.name} County, ${county.state}`,
      type: 'AdministrativeArea',
      lat: county.geo.lat,
      lng: county.geo.lng,
    },
  }),
  ...(citiesInCounty.length
    ? [
        itemListSchema({
          name: `Cities ATLStay manages in ${county.name} County, GA`,
          items: citiesInCounty.map((c) => ({
            name: `${c.data.name}, ${c.data.state}`,
            path: `/${c.data.slug}/`,
            description: c.data.description,
          })),
        }),
      ]
    : []),
];
---

<BaseLayout title={seoTitle} description={seoDesc} schemas={schemas}>
  <PageHero
    title={heading}
    subtitle={county.intro}
    eyebrow={`${county.name} County · ${county.tagline}`}
    imageKey="atlantaSkyline"
    breadcrumbs={[
      { name: 'Home', path: '/' },
      { name: 'Areas We Serve', path: '/areas-we-serve/' },
      { name: 'Counties', path: '/counties/' },
      { name: `${county.name} County`, path: `/counties/${county.slug}/` },
    ]}
    cta={{ label: 'Get my free rental projection', href: '/rental-projection/' }}
    secondaryCta={{ label: 'All areas we serve', href: '/areas-we-serve/' }}
    size="lg"
  />

  <!-- What we deliver -->
  <Section variant="cream">
    <Container>
      <div class="grid gap-12 lg:grid-cols-2 lg:items-start lg:gap-20">
        <div>
          <Eyebrow>What we deliver</Eyebrow>
          <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">Full-service management across {county.name} County</h2>
          <p data-speakable class="mt-4 text-ink/80">
            ATLStay handles every part of a {county.name} County short-term rental — listing creation and photography, dynamic pricing, 24/7 guest communication, cleaning, and turnovers. One transparent rate, {site.pricing.rateNote}.
          </p>
          <Button href="/services/" variant="secondary" class="mt-6">See all services &rarr;</Button>
        </div>
        <div class="rounded-2xl border border-line bg-white p-8">
          <h3 class="font-display text-lg text-forest">Why {county.name} County</h3>
          <p data-speakable class="mt-4 text-ink/80">{county.demand}</p>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Cities in this county -->
  {citiesInCounty.length > 0 && (
    <Section variant="white">
      <Container size="wide">
        <div class="mb-10 text-center">
          <Eyebrow>{county.name} County</Eyebrow>
          <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">Cities we manage in {county.name} County</h2>
          <p class="mx-auto mt-4 max-w-2xl text-ink/70">
            Each {county.name} County city brings its own demand profile and guest mix. We manage properties across all of them.
          </p>
        </div>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {citiesInCounty.map((c, i) => (
            <NeighborhoodCard
              name={c.data.name}
              href={`/${c.data.slug}/`}
              gradient={styles[i].gradient}
              icon={styles[i].icon}
              blurb={c.data.intro.split('.')[0] + '.'}
            />
          ))}
        </div>
      </Container>
    </Section>
  )}

  <!-- Why local management matters -->
  <Section variant="forest">
    <Container>
      <div class="mx-auto max-w-3xl text-center">
        <Eyebrow class="text-brass">Local vs. national</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-cream sm:text-4xl">The {county.name} County advantage: local knowledge at every level</h2>
        <p class="mt-5 text-cream/80">
          National STR platforms run algorithms, not relationships — pricing from national datasets, remote contractor turnovers, and call-center support with no feel for {county.name} County's specific demand patterns or city-by-city regulatory landscape. ATLStay manages owner-by-owner with local pricing intelligence and the vendor network to make turnovers reliable and reviews five-star.
        </p>
        <Button href="/rental-projection/" size="lg" class="mt-10">Get my free {county.name} County projection</Button>
      </div>
    </Container>
  </Section>

  <!-- Regulations -->
  <Section variant="cream">
    <Container>
      <div class="rounded-2xl border border-line bg-white px-8 py-10">
        <div class="grid gap-8 lg:grid-cols-[2fr_1fr] lg:items-center">
          <div>
            <Eyebrow>Regulatory compliance</Eyebrow>
            <h2 class="mt-3 font-display text-2xl text-forest sm:text-3xl">{county.name} County short-term rental rules</h2>
            <p data-speakable class="mt-4 text-ink/80">{county.regulationsNote}</p>
            <p class="mt-3 text-ink/80">Always confirm the latest rules with the relevant local authority before listing — we'll point you to exactly what applies to your property.</p>
          </div>
          <Button href="/resources/atlanta-short-term-rental-regulations/" variant="secondary" class="self-start text-center">Georgia STR regulations guide &rarr;</Button>
        </div>
      </div>
    </Container>
  </Section>

  <!-- FAQ -->
  {county.faqs.length > 0 && (
    <Section variant="white">
      <Container size="narrow">
        <Eyebrow>Common questions</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-forest sm:text-4xl">{county.name} County STR management — FAQs</h2>
        <div class="mt-8"><FAQ items={county.faqs} /></div>
      </Container>
    </Section>
  )}

  <CTABand
    heading={`Ready to maximize your ${county.name} County property?`}
    text="Get a free, comps-based rental projection from our local team — no sales pitch, just honest local data."
  />
</BaseLayout>
