---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';
import CTABand from '@/components/ui/CTABand.astro';
import PageHero from '@/components/ui/PageHero.astro';
import { breadcrumbSchema } from '@/lib/schema';

const allResources = await getCollection('resources', (entry) => !entry.data.draft);
const resources = allResources.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const schemas = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Resources', path: '/resources/' },
  ]),
];

// Group by category for the topic filter. Show chips in a deliberate, logical
// order (location → money → operations → compliance) rather than by recency.
const CATEGORY_ORDER = [
  'Atlanta Neighborhoods',
  'Georgia Markets',
  'Investing & ROI',
  'Pricing & Revenue',
  'Marketing & Listings',
  'Hosting & Operations',
  'Regulations & Taxes',
];
const orderOf = (c: string) => {
  const i = CATEGORY_ORDER.indexOf(c);
  return i === -1 ? CATEGORY_ORDER.length : i;
};
const categories = [...new Set(resources.map((r) => r.data.category))].sort(
  (a, b) => orderOf(a) - orderOf(b) || a.localeCompare(b),
);
const featured = resources.filter((r) => r.data.featured);
---

<BaseLayout
  title="Atlanta STR Owner Resources — Fees, Regulations & Guides"
  description="Practical guides for Atlanta Airbnb hosts: management fees explained, short-term rental regulations, and how to decide if professional management is right for you."
  schemas={schemas}
>
  <PageHero
    title="Honest guides for Atlanta STR owners"
    subtitle="Everything you need to understand fees, navigate regulations, and decide whether professional management makes sense for your property."
    eyebrow="Owner Resources"
    imageKey="photography"
    breadcrumbs={[{ name: 'Home', path: '/' }, { name: 'Resources', path: '/resources/' }]}
  />

  <!-- Featured guides -->
  {featured.length > 0 && (
    <Section variant="white">
      <Container>
        <div class="flex items-end justify-between gap-4">
          <div>
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-brass-600">Start here</span>
            <h2 class="mt-2 font-display text-2xl text-forest sm:text-3xl">Featured guides</h2>
          </div>
          <p class="hidden text-sm text-stone sm:block">{resources.length} owner guides and counting</p>
        </div>
        <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {featured.map((entry) => (
            <article class="group flex flex-col rounded-2xl border border-brass/30 bg-brass-50/40 p-6 shadow-sm transition-all hover:-translate-y-0.5 hover:border-brass/60 hover:shadow-md">
              <Badge variant="brass">{entry.data.category}</Badge>
              <h3 class="mt-4 font-display text-xl leading-snug text-forest">
                <a href={`/resources/${entry.id}/`} class="transition-colors group-hover:text-brass-600">{entry.data.title}</a>
              </h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-ink/75">{entry.data.description}</p>
              <span class="mt-4 text-sm font-medium text-brass-600">Read the guide &rarr;</span>
            </article>
          ))}
        </div>
      </Container>
    </Section>
  )}

  <!-- Resource cards + client-side topic filter -->
  <Section variant="cream">
    <Container>
      <div class="mb-2">
        <span class="text-xs font-semibold uppercase tracking-[0.18em] text-brass-600">All guides</span>
        <h2 class="mt-2 font-display text-2xl text-forest sm:text-3xl">Browse every guide</h2>
      </div>
    </Container>
    <Container>
      {categories.length > 1 && (
        <div class="mb-10 flex flex-wrap items-center gap-2">
          <span class="mr-1 text-xs font-semibold uppercase tracking-[0.18em] text-stone">Browse by topic</span>
          <button type="button" data-filter="all" aria-pressed="true" class="cursor-pointer rounded-full px-4 py-1.5 text-sm font-medium ring-1 ring-line text-stone transition-colors hover:text-forest hover:ring-brass/50 aria-pressed:bg-forest aria-pressed:text-cream aria-pressed:ring-forest">All</button>
          {categories.map((cat) => (
            <button type="button" data-filter={cat} aria-pressed="false" class="cursor-pointer rounded-full px-4 py-1.5 text-sm font-medium ring-1 ring-line text-stone transition-colors hover:text-forest hover:ring-brass/50 aria-pressed:bg-forest aria-pressed:text-cream aria-pressed:ring-forest">{cat}</button>
          ))}
        </div>
      )}
      <div id="resource-grid" class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {resources.map((entry) => (
          <article data-category={entry.data.category} class="flex flex-col rounded-2xl border border-line bg-white overflow-hidden shadow-sm transition-shadow hover:shadow-md">
            <!-- Category badge -->
            <div class="px-6 pt-6">
              <Badge variant="brass">{entry.data.category}</Badge>
            </div>

            <!-- Content -->
            <div class="flex flex-1 flex-col px-6 pb-6 pt-4">
              <h2 class="font-display text-xl text-forest leading-snug">
                <a
                  href={`/resources/${entry.id}/`}
                  class="hover:text-brass-600 transition-colors"
                >
                  {entry.data.title}
                </a>
              </h2>
              <p class="mt-2 text-sm text-stone leading-relaxed flex-1">
                {entry.data.description}
              </p>
              <div class="mt-5 flex items-center justify-between">
                <time
                  datetime={entry.data.publishDate.toISOString()}
                  class="text-xs text-stone"
                >
                  {entry.data.publishDate.toLocaleDateString('en-US', {
                    month: 'long',
                    day: 'numeric',
                    year: 'numeric',
                  })}
                </time>
                <Button
                  href={`/resources/${entry.id}/`}
                  variant="ghost"
                  size="md"
                >
                  Read →
                </Button>
              </div>
            </div>
          </article>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Internal link callouts -->
  <Section variant="white">
    <Container size="narrow">
      <h2 class="font-display text-2xl text-forest text-center mb-8">
        Explore more
      </h2>
      <div class="grid gap-4 sm:grid-cols-3 text-center">
        <a href="/pricing/" class="rounded-xl border border-line p-5 hover:border-brass transition-colors group">
          <div class="font-display text-lg text-forest group-hover:text-brass-600 transition-colors">Pricing &amp; Fees</div>
          <p class="mt-1 text-sm text-stone">See our transparent, all-inclusive rate</p>
        </a>
        <a href="/services/" class="rounded-xl border border-line p-5 hover:border-brass transition-colors group">
          <div class="font-display text-lg text-forest group-hover:text-brass-600 transition-colors">Our Services</div>
          <p class="mt-1 text-sm text-stone">Everything we handle on your behalf</p>
        </a>
        <a href="/rental-projection/" class="rounded-xl border border-line p-5 hover:border-brass transition-colors group">
          <div class="font-display text-lg text-forest group-hover:text-brass-600 transition-colors">Free Projection</div>
          <p class="mt-1 text-sm text-stone">What could your home earn?</p>
        </a>
      </div>
    </Container>
  </Section>

  <CTABand />
</BaseLayout>

<script>
  // Client-side topic filter for the resource grid.
  const chips = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const cards = document.querySelectorAll<HTMLElement>('#resource-grid [data-category]');
  chips.forEach((chip) =>
    chip.addEventListener('click', () => {
      const f = chip.dataset.filter;
      chips.forEach((c) => c.setAttribute('aria-pressed', String(c === chip)));
      cards.forEach((card) => {
        card.style.display = f === 'all' || card.dataset.category === f ? '' : 'none';
      });
    }),
  );
</script>
