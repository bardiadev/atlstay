---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import Eyebrow from '@/components/ui/Eyebrow.astro';
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';
import CTABand from '@/components/ui/CTABand.astro';
import { breadcrumbSchema } from '@/lib/schema';

const allResources = await getCollection('resources', (entry) => !entry.data.draft);
const resources = allResources.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const schemas = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Resources', path: '/resources/' },
  ]),
];

// Group by category for nav/filtering purposes
const categories = [...new Set(resources.map((r) => r.data.category))];
---

<BaseLayout
  title="Atlanta STR Owner Resources — Fees, Regulations & Guides"
  description="Practical guides for Atlanta Airbnb hosts: management fees explained, short-term rental regulations, and how to decide if professional management is right for you."
  schemas={schemas}
>
  <!-- Hero -->
  <Section variant="forest">
    <Container size="narrow">
      <Eyebrow class="text-brass">Owner Resources</Eyebrow>
      <h1 class="mt-3 font-display text-4xl text-cream sm:text-5xl">
        Honest guides for Atlanta STR owners
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-cream/80">
        Everything you need to understand fees, navigate regulations, and decide whether professional management makes sense for your property.
      </p>
    </Container>
  </Section>

  <!-- Category nav (visible if multiple categories) -->
  {categories.length > 1 && (
    <Section variant="white" class="py-6">
      <Container>
        <div class="flex flex-wrap gap-2">
          {categories.map((cat) => (
            <Badge variant="outline">{cat}</Badge>
          ))}
        </div>
      </Container>
    </Section>
  )}

  <!-- Resource cards -->
  <Section variant="cream">
    <Container>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {resources.map((entry) => (
          <article class="flex flex-col rounded-2xl border border-line bg-white overflow-hidden shadow-sm transition-shadow hover:shadow-md">
            <!-- Category badge -->
            <div class="px-6 pt-6">
              <Badge variant="brass">{entry.data.category}</Badge>
            </div>

            <!-- Content -->
            <div class="flex flex-1 flex-col px-6 pb-6 pt-4">
              <h2 class="font-display text-xl text-forest leading-snug">
                <a
                  href={`/resources/${entry.id}/`}
                  class="hover:text-brass-600 transition-colors"
                >
                  {entry.data.title}
                </a>
              </h2>
              <p class="mt-2 text-sm text-stone leading-relaxed flex-1">
                {entry.data.description}
              </p>
              <div class="mt-5 flex items-center justify-between">
                <time
                  datetime={entry.data.publishDate.toISOString()}
                  class="text-xs text-stone"
                >
                  {entry.data.publishDate.toLocaleDateString('en-US', {
                    month: 'long',
                    day: 'numeric',
                    year: 'numeric',
                  })}
                </time>
                <Button
                  href={`/resources/${entry.id}/`}
                  variant="ghost"
                  size="md"
                >
                  Read →
                </Button>
              </div>
            </div>
          </article>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Internal link callouts -->
  <Section variant="white">
    <Container size="narrow">
      <h2 class="font-display text-2xl text-forest text-center mb-8">
        Explore more
      </h2>
      <div class="grid gap-4 sm:grid-cols-3 text-center">
        <a href="/pricing/" class="rounded-xl border border-line p-5 hover:border-brass transition-colors group">
          <div class="font-display text-lg text-forest group-hover:text-brass-600 transition-colors">Pricing &amp; Fees</div>
          <p class="mt-1 text-sm text-stone">See our transparent, all-inclusive rate</p>
        </a>
        <a href="/services/" class="rounded-xl border border-line p-5 hover:border-brass transition-colors group">
          <div class="font-display text-lg text-forest group-hover:text-brass-600 transition-colors">Our Services</div>
          <p class="mt-1 text-sm text-stone">Everything we handle on your behalf</p>
        </a>
        <a href="/rental-projection/" class="rounded-xl border border-line p-5 hover:border-brass transition-colors group">
          <div class="font-display text-lg text-forest group-hover:text-brass-600 transition-colors">Free Projection</div>
          <p class="mt-1 text-sm text-stone">What could your home earn?</p>
        </a>
      </div>
    </Container>
  </Section>

  <CTABand />
</BaseLayout>
