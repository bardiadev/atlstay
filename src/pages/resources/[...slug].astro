---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import Eyebrow from '@/components/ui/Eyebrow.astro';
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';
import Prose from '@/components/ui/Prose.astro';
import FAQ from '@/components/ui/FAQ.astro';
import CTABand from '@/components/ui/CTABand.astro';
import { breadcrumbSchema, articleSchema } from '@/lib/schema';
import { images } from '@/data/images';
import type { ImageKey } from '@/data/images';

export async function getStaticPaths() {
  const resources = await getCollection('resources', (entry) => !entry.data.draft);
  return resources.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const heroImageKey = entry.data.heroImage as ImageKey | undefined;
const heroImg = heroImageKey && heroImageKey in images ? images[heroImageKey] : null;

const schemas = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Resources', path: '/resources/' },
    { name: entry.data.title, path: `/resources/${entry.id}/` },
  ]),
  articleSchema({
    title: entry.data.title,
    description: entry.data.description,
    path: `/resources/${entry.id}/`,
    datePublished: entry.data.publishDate,
    dateModified: entry.data.updatedDate ?? entry.data.publishDate,
    image: heroImg?.src,
  }),
];
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  image={heroImg?.src}
  ogType="article"
  schemas={schemas}
>
  <!-- Hero -->
  <Section variant="forest">
    <Container size="narrow">
      <div class="flex items-center gap-3 mb-4">
        <a
          href="/resources/"
          class="text-sm text-cream/60 hover:text-brass transition-colors"
        >
          ← Resources
        </a>
        <span class="text-cream/30">|</span>
        <Badge variant="brass">{entry.data.category}</Badge>
      </div>
      <h1 class="font-display text-3xl text-cream sm:text-4xl lg:text-5xl leading-tight">
        {entry.data.title}
      </h1>
      <p class="mt-4 text-lg text-cream/80 max-w-2xl">
        {entry.data.description}
      </p>
      <p class="mt-4 text-sm text-cream/50">
        Published{' '}
        <time datetime={entry.data.publishDate.toISOString()}>
          {entry.data.publishDate.toLocaleDateString('en-US', {
            month: 'long',
            day: 'numeric',
            year: 'numeric',
          })}
        </time>
        {entry.data.updatedDate && (
          <span>
            {' · Updated '}
            <time datetime={entry.data.updatedDate.toISOString()}>
              {entry.data.updatedDate.toLocaleDateString('en-US', {
                month: 'long',
                day: 'numeric',
                year: 'numeric',
              })}
            </time>
          </span>
        )}
      </p>
    </Container>
  </Section>

  <!-- Hero image -->
  {heroImg && (
    <div class="aspect-[16/6] w-full overflow-hidden bg-forest-50">
      <img
        src={heroImg.src}
        alt={heroImg.alt}
        class="h-full w-full object-cover"
        loading="eager"
      />
    </div>
  )}

  <!-- Article body -->
  <Section variant="white">
    <Container size="narrow">
      <Prose>
        <Content />
      </Prose>
    </Container>
  </Section>

  <!-- FAQ section (if entry has faqs) -->
  {entry.data.faqs.length > 0 && (
    <Section variant="cream" id="faq">
      <Container size="narrow">
        <Eyebrow>Common Questions</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-forest">
          Frequently Asked Questions
        </h2>
        <div class="mt-8">
          <FAQ items={entry.data.faqs} />
        </div>
      </Container>
    </Section>
  )}

  <!-- Related resources / back link -->
  <Section variant="white">
    <Container size="narrow">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 py-4 border-t border-line">
        <div>
          <p class="text-sm text-stone">Looking for more owner guides?</p>
          <a
            href="/resources/"
            class="font-display text-forest hover:text-brass-600 transition-colors"
          >
            ← Back to all resources
          </a>
        </div>
        <div class="flex flex-wrap gap-3">
          <Button href="/pricing/" variant="secondary" size="md">
            See our pricing
          </Button>
          <Button href="/rental-projection/" variant="primary" size="md">
            Get my free projection
          </Button>
        </div>
      </div>
    </Container>
  </Section>

  <CTABand />
</BaseLayout>
